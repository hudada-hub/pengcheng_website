{{!-- Our Customers�? 行网�?+ �?about-us 相同的列步进/拖拽（home-customers-carousel.js，非 Swiper�?--}}
{{#if customerLogosGrid.length}}
<section class="g-section g-customers" aria-label="Our Customers">
  <div class="container">
    <h2 class="g-section-title">{{#if ourCustomersTitle}}{{ourCustomersTitle}}{{else}}OUR CUSTOMERS{{/if}}</h2>

    <div class="g-customers__slider-outer">
      <div class="g-customers__slider">
        <div class="g-customers__swiper" id="home-customers-swiper">
          <ul class="g-customers__track" id="home-customers-track" role="list">
            {{#each customerLogosGrid}}
            <li class="g-customers__slide">
              <div class="g-customers__card">
                <img src="{{url}}" alt="{{name}}" class="g-customers__logo" loading="lazy" decoding="async" draggable="false" />
              </div>
            </li>
            {{/each}}
          </ul>
        </div>
      </div>

      <button
        type="button"
        class="g-customers__nav g-customers__nav--prev"
        id="home-customers-prev"
        aria-label="{{#if (eq locale 'cn')}}上一�?Logo{{else}}Previous logos{{/if}}"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
      <button
        type="button"
        class="g-customers__nav g-customers__nav--next"
        id="home-customers-next"
        aria-label="{{#if (eq locale 'cn')}}下一�?Logo{{else}}Next logos{{/if}}"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</section>
{{/if}}
