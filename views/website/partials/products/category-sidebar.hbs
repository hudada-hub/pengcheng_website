{{!-- Products Category Sidebar：白底卡�?+ 深色标题；一级手风琴、二级复选框 + 数量 --}}
<aside class="g-products-sidebar">
  <div class="g-products-sidebar__inner">
    <div class="g-products-sidebar__header">
      <button class="g-products-sidebar__toggle" id="categoryToggleBtn" type="button" aria-expanded="false" aria-controls="categoryList">
        <span class="g-products-sidebar__title">
          {{#if productTexts.allProducts}}{{productTexts.allProducts}}{{else}}{{#if (eq locale "zh-CN")}}全部产品{{else}}All Products{{/if}}{{/if}}
        </span>
      </button>
    </div>

    <div class="g-products-sidebar__content" id="categoryList">
      <ul class="g-products-sidebar__list" role="list">
        {{#each categoryTree}}
          {{#if (hasCategoryChildren this)}}
            <li class="g-products-sidebar__item g-products-sidebar__item--accordion">
              <div class="g-products-sidebar__acc">
                <button
                  type="button"
                  class="g-products-sidebar__l1-trigger"
                  aria-expanded="{{#if this.expanded}}true{{else}}false{{/if}}"
                  aria-controls="category-sub-{{@index}}"
                  id="category-acc-{{@index}}"
                >
                  <span class="g-products-sidebar__l1-text">{{this.title}}</span>
                  <span class="g-products-sidebar__chev" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
                <ul
                  class="g-products-sidebar__l2{{#if this.expanded}} is-open{{/if}}"
                  id="category-sub-{{@index}}"
                  role="list"
                  aria-labelledby="category-acc-{{@index}}"
                >
                  {{#each this.children}}
                    {{#unless this.isProduct}}
                      <li class="g-products-sidebar__l2-item">
                        <label class="g-products-sidebar__l2-row">
                          <input
                            type="radio"
                            name="category"
                            class="g-products-category__checkbox"
                            data-category-url="{{this.url}}"
                            {{#if this.selected}}checked{{/if}}
                          />
                          <span class="g-products-category__checkmark"></span>
                          <a href="{{this.url}}" class="g-products-sidebar__l2-link{{#if this.active}} is-active{{/if}}">
                            <span class="g-products-sidebar__l2-name">{{this.title}}</span>
                          </a>
                          <span class="g-products-sidebar__count">({{this.productCount}})</span>
                        </label>
                      </li>
                    {{/unless}}
                  {{/each}}
                </ul>
              </div>
            </li>
          {{else}}
            <li class="g-products-sidebar__item g-products-sidebar__item--leaf">
              <label class="g-products-sidebar__l2-row g-products-sidebar__l2-row--root">
                <a href="{{this.url}}" class="g-products-sidebar__l2-link g-products-sidebar__l2-link--root{{#if this.active}} is-active{{/if}}">
                  <span class="g-products-sidebar__l2-name">{{this.title}}</span>
                </a>
                <span class="g-products-sidebar__count">({{this.productCount}})</span>
              </label>
            </li>
          {{/if}}
        {{/each}}
      </ul>
    </div>
  </div>
</aside>
