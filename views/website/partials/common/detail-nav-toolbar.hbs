{{!--
  detail-nav-toolbar
  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  йҖҡз”ЁиҜҰжғ…йЎөеҜјиҲӘе·Ҙе…·ж Ҹ + еҲҶдә«еј№зӘ—з»„д»¶гҖ?
  ж”ҫзҪ®дә?.g-case-detail-layout__inner еҶ?<article> д№ӢеҗҺпј?
    вҖ?<aside> дҪңдёә flex itemпјҢеңЁжЎҢйқўз«ҜжҳҫзӨәеңЁж–Үз« еҸідҫ§
    вҖ?<nav>   position:fixedпјҢеә•йғЁжӮ¬жө®пјҢдёҚеҪұе“?flex еёғеұҖ
    вҖ?дёӨдёӘеј№зӘ—еқ?position:fixedпјҢDOM дҪҚзҪ®ж— еҪұе“?

  и°ғз”ЁзӨәдҫӢпјҲcase-detail.hbsпјүпјҡ
    {{> website/common/detail-nav-toolbar
        prevItem=casePrev
        nextItem=caseNext
        listUrl=casesListUrl
    }}

  йңҖд»ҺзҲ¶зә§дёҠдёӢж–Үз»§жүҝзҡ„еҸҳйҮҸпјҡ
    locale          еҪ“еүҚиҜӯиЁҖд»Јз ҒпјҲzh-CN / en / ja вҖҰпјү
    shareTypes      еҲҶдә«зұ»еһӢж•°з»„ [{type, label, iconUrl}]
    shareModalTitle еҲҶдә«еј№зӘ—ж ҮйўҳпјҲеҸҜдёәз©әпј?
--}}

{{!-- ===== жЎҢйқўз«Ҝдҫ§иҫ№е·Ҙе…·ж Ҹ ===== --}}
<aside
  class="g-case-detail-toolbar d-none d-lg-flex"
  aria-label="{{#if (eq locale 'zh-CN')}}ж“ҚдҪң{{else}}Actions{{/if}}"
>
  {{!-- дёӢдёҖжқ?--}}
  {{#if nextItem}}
  <a
    href="{{nextItem.url}}"
    class="g-case-detail-toolbar__btn"
    title="{{nextItem.title}}"
    aria-label="{{#if (eq locale 'zh-CN')}}дёӢдёҖжқЎ{{else}}Next{{/if}}"
  >
    <iconify-icon icon="mdi:chevron-right"></iconify-icon>
  </a>
  {{else}}
  <span
    class="g-case-detail-toolbar__btn is-disabled"
    aria-disabled="true"
    aria-label="{{#if (eq locale 'zh-CN')}}ж— дёӢдёҖжқЎ{{else}}No next{{/if}}"
  >
    <iconify-icon icon="mdi:chevron-right"></iconify-icon>
  </span>
  {{/if}}

  {{!-- дёҠдёҖжқ?--}}
  {{#if prevItem}}
  <a
    href="{{prevItem.url}}"
    class="g-case-detail-toolbar__btn"
    title="{{prevItem.title}}"
    aria-label="{{#if (eq locale 'zh-CN')}}дёҠдёҖжқЎ{{else}}Previous{{/if}}"
  >
    <iconify-icon icon="mdi:chevron-left"></iconify-icon>
  </a>
  {{else}}
  <span
    class="g-case-detail-toolbar__btn is-disabled"
    aria-disabled="true"
    aria-label="{{#if (eq locale 'zh-CN')}}ж— дёҠдёҖжқЎ{{else}}No previous{{/if}}"
  >
    <iconify-icon icon="mdi:chevron-left"></iconify-icon>
  </span>
  {{/if}}

  {{!-- еҲҶдә« --}}
  <button
    type="button"
    class="g-case-detail-toolbar__btn"
    data-case-action="native-share"
    aria-label="{{#if (eq locale 'zh-CN')}}еҲҶдә«{{else}}Share{{/if}}"
  >
    <iconify-icon icon="mdi:share-variant"></iconify-icon>
  </button>

  {{!-- иҝ”еӣһеҲ—иЎЁ --}}
  <a
    href="{{listUrl}}"
    class="g-case-detail-toolbar__btn"
    aria-label="{{#if (eq locale 'zh-CN')}}иҝ”еӣһеҲ—иЎЁ{{else}}Back to list{{/if}}"
  >
    <iconify-icon icon="mdi:undo-variant"></iconify-icon>
  </a>
</aside>

{{!-- ===== з§»еҠЁз«Ҝеә•йғЁеӣәе®ҡе·Ҙе…·ж Ҹ ===== --}}
<nav
  class="g-case-detail-toolbar-mobile d-lg-none"
  aria-label="{{#if (eq locale 'zh-CN')}}ж“ҚдҪң{{else}}Actions{{/if}}"
>
  <div class="g-case-detail-toolbar-mobile__inner">
    {{!-- дёӢдёҖжқ?--}}
    {{#if nextItem}}
    <a
      href="{{nextItem.url}}"
      class="g-case-detail-toolbar__btn"
      title="{{nextItem.title}}"
      aria-label="{{#if (eq locale 'zh-CN')}}дёӢдёҖжқЎ{{else}}Next{{/if}}"
    >
      <iconify-icon icon="mdi:chevron-right"></iconify-icon>
    </a>
    {{else}}
    <span class="g-case-detail-toolbar__btn is-disabled" aria-disabled="true">
      <iconify-icon icon="mdi:chevron-right"></iconify-icon>
    </span>
    {{/if}}

    {{!-- дёҠдёҖжқ?--}}
    {{#if prevItem}}
    <a
      href="{{prevItem.url}}"
      class="g-case-detail-toolbar__btn"
      title="{{prevItem.title}}"
      aria-label="{{#if (eq locale 'zh-CN')}}дёҠдёҖжқЎ{{else}}Previous{{/if}}"
    >
      <iconify-icon icon="mdi:chevron-left"></iconify-icon>
    </a>
    {{else}}
    <span class="g-case-detail-toolbar__btn is-disabled" aria-disabled="true">
      <iconify-icon icon="mdi:chevron-left"></iconify-icon>
    </span>
    {{/if}}

    {{!-- еҲҶдә« --}}
    <button
      type="button"
      class="g-case-detail-toolbar__btn"
      data-case-action="native-share"
      aria-label="{{#if (eq locale 'zh-CN')}}еҲҶдә«{{else}}Share{{/if}}"
    >
      <iconify-icon icon="mdi:share-variant"></iconify-icon>
    </button>

    {{!-- иҝ”еӣһеҲ—иЎЁ --}}
    <a
      href="{{listUrl}}"
      class="g-case-detail-toolbar__btn"
      aria-label="{{#if (eq locale 'zh-CN')}}иҝ”еӣһеҲ—иЎЁ{{else}}Back to list{{/if}}"
    >
      <iconify-icon icon="mdi:undo-variant"></iconify-icon>
    </a>
  </div>
</nav>

{{!-- ===== еҲҶдә«е№іеҸ°йҖүжӢ©еј№зӘ— ===== --}}
<div
  id="g-share-modal"
  class="g-share-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="{{#if shareModalTitle}}{{shareModalTitle}}{{else}}{{#if (eq locale 'zh-CN')}}еҲҶдә«{{else}}Share{{/if}}{{/if}}"
>
  <div class="g-share-modal__overlay" data-share-close></div>
  <div class="g-share-modal__content">
    <div class="g-share-modal__header">
      <h3 class="g-share-modal__title">
        {{#if shareModalTitle}}{{shareModalTitle}}{{else}}{{#if (eq locale 'zh-CN')}}еҲҶдә«{{else}}Share{{/if}}{{/if}}
      </h3>
      <button
        type="button"
        class="g-share-modal__close"
        data-share-close
        aria-label="{{#if (eq locale 'zh-CN')}}е…ій—ӯ{{else}}Close{{/if}}"
      >
        <iconify-icon icon="mdi:close"></iconify-icon>
      </button>
    </div>
    <div class="g-share-modal__body">
      <div class="g-share-modal__items">
        {{#each shareTypes}}
        <button
          type="button"
          class="g-share-modal__item"
          data-share-type="{{this.type}}"
          data-share-label="{{this.label}}"
        >
          {{#if this.iconUrl}}
          <img
            src="{{this.iconUrl}}"
            alt="{{this.label}}"
            class="g-share-modal__icon"
            loading="lazy"
          >
          {{else}}
          <span class="g-share-modal__icon-fallback">{{this.label}}</span>
          {{/if}}
          <span class="g-share-modal__label">{{this.label}}</span>
        </button>
        {{/each}}
      </div>
    </div>
  </div>
</div>

{{!-- ===== еҫ®дҝЎдәҢз»ҙз Ғеј№зӘ?===== --}}
<div
  id="g-wechat-qr-modal"
  class="g-share-modal g-wechat-qr-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="{{#if (eq locale 'zh-CN')}}еҲҶдә«еҲ°еҫ®дҝЎ{{else}}Share to WeChat{{/if}}"
>
  <div class="g-share-modal__overlay" data-wechat-close></div>
  <div class="g-share-modal__content">
    <div class="g-share-modal__header">
      <h3 class="g-share-modal__title">
        {{#if (eq locale 'zh-CN')}}еҲҶдә«еҲ°еҫ®дҝЎ{{else}}Share to WeChat{{/if}}
      </h3>
      <button
        type="button"
        class="g-share-modal__close"
        data-wechat-close
        aria-label="{{#if (eq locale 'zh-CN')}}е…ій—ӯ{{else}}Close{{/if}}"
      >
        <iconify-icon icon="mdi:close"></iconify-icon>
      </button>
    </div>
    <div class="g-share-modal__body">
      <div class="g-wechat-qr-modal__qr" id="g-wechat-qr-container"></div>
      <p class="g-wechat-qr-modal__tip">
        {{#if (eq locale 'zh-CN')}}жү“ејҖеҫ®дҝЎжү«дёҖжү«{{else}}Open WeChat and scan{{/if}}
      </p>
    </div>
  </div>
</div>
