{{!-- 椤甸潰璁块棶涓婃姤锛氶渶 SSR 鎻愪緵 langId銆乸ageViewPageType锛堟捣澶?global 鍚勯〉娉ㄥ叆锛?--}}
{{#if pageViewPageType}}
{{#if langId}}
<script>
(function () {
  var langId = {{langId}};
  var pageType = {{{json pageViewPageType}}};
  try {
    var path = (window.location.pathname || '') + (window.location.search || '');
    if (path.length > 2000) path = path.slice(0, 2000);
    var body = JSON.stringify({
      langId: langId,
      pageUrl: path,
      pageType: pageType,
      browser: navigator.userAgent || ''
    });
    fetch('/api/page-view', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: body,
      keepalive: true,
      credentials: 'same-origin'
    }).catch(function () {});
  } catch (e) {}
})();
</script>
{{/if}}
{{/if}}
