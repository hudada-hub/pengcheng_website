{{!-- Footer - multi-column layout (Figma design) --}}
<footer class="g-footer" role="contentinfo">
  {{#if (eq locale 'cn')}}
  {{!-- 中文版本 - 根据Figma设计 --}}
  <div class="container" style="box-sizing: border-box;">
    <div class="g-footer__wrap g-footer__wrap--cn">
      {{!-- Column 1: Logo + 公司标语 --}}
      <div class="g-footer__col g-footer__col--cn g-footer__col--logo-cn" style="margin-right:3rem;">
        <div class="g-footer__logo-section g-footer__logo-section--cn">
          <div class="g-footer__logo g-footer__logo--cn">
            {{#if followUs.bgPicUrl}}
            <img src="{{followUs.bgPicUrl}}" alt="{{#if followUs.title}}{{followUs.title}}{{else}}Logo{{/if}}" loading="lazy" />
            {{/if}}
          </div>
          <div class="g-footer__divider g-footer__divider--cn"></div>
          <p class="g-footer__tagline g-footer__tagline--cn" >{{footerAboutUs.description}}</p>
        </div>
      </div>

      {{!-- Column 2: 工程机械 + 储能 (navItems[0] + navItems[1]) --}}
      <div class="g-footer__col g-footer__col--cn">
        {{#with (lookup navItems 0)}}
          <p class="g-footer__col-title g-footer__col-title--cn">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}
        
        {{#with (lookup navItems 1)}}
          <p class="g-footer__col-title g-footer__col-title--cn" style="margin-top: 24px;">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 3: 动力电池 (navItems[2]) --}}
      <div class="g-footer__col g-footer__col--cn">
        {{#with (lookup navItems 2)}}
          <p class="g-footer__col-title g-footer__col-title--cn">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 4: 解决方案、服务、发现、公司 (navItems[3] + navItems[4] + navItems[5] + navItems[6]) --}}
      <div class="g-footer__col g-footer__col--cn">
        {{#with (lookup navItems 3)}}
          <p class="g-footer__col-title g-footer__col-title--cn">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}
        
        {{#with (lookup navItems 4)}}
          <p class="g-footer__col-title g-footer__col-title--cn" style="margin-top: 24px;">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}
        
        {{#with (lookup navItems 5)}}
          <p class="g-footer__col-title g-footer__col-title--cn" style="margin-top: 24px;">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}
        
        {{#with (lookup navItems 6)}}
          <p class="g-footer__col-title g-footer__col-title--cn" style="margin-top: 24px;">{{title}}</p>
          {{#if children}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            {{#each children}}
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul class="g-footer__nav-list g-footer__nav-list--cn">
            <li><a class="g-footer__navlink g-footer__navlink--cn" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 5: 联系我们 --}}
      <div class="g-footer__col g-footer__col--cn g-footer__col--contact-cn">
        <p class="g-footer__col-title g-footer__col-title--cn g-footer__col-title--contact">{{footerAboutUs.title}}</p>
        <div class="g-footer__contact-block g-footer__contact-block--cn">
          {{#each footerAboutUs.emailItems}}
          <div class="g-footer__contact-item g-footer__contact-item--cn">
            <p class="g-footer__contact-label g-footer__contact-label--cn">{{label}}</p>
            <a href="mailto:{{email}}" class="g-footer__contact-link g-footer__contact-link--cn">{{email}}</a>
          </div>
          {{/each}}
          <div class="g-footer__contact-item g-footer__contact-item--cn">
            <p class="g-footer__contact-label g-footer__contact-label--cn">{{footerPhone.label}}</p>
            <a href="tel:{{footerPhone.phone}}" class="g-footer__contact-link g-footer__contact-link--cn">{{footerPhone.phone}}</a>
          </div>
        </div>
        <div class="g-footer__social g-footer__social--cn">
          {{#if followUs.items}}
            {{#each followUs.items}}
            <a href="{{#if url}}{{url}}{{else}}#{{/if}}" target="_blank" rel="noopener noreferrer" class="g-footer__social-link g-footer__social-link--cn" aria-label="{{#if title}}{{title}}{{else}}social{{/if}}">
              <img src="{{picUrl}}" alt="{{#if title}}{{title}}{{else}}social{{/if}}" loading="lazy" />
            </a>
            {{/each}}
          {{/if}}
        </div>
      </div>
    </div>
  </div>
  {{else}}
  {{!-- 英文版本 - 保持原有结构 --}}
  <div class="container" style="box-sizing: border-box;">
    <div class="g-footer__wrap">
      {{!-- Column 1: 使用与顶部导航一致的前两组一级菜单 --}}
      <div class="g-footer__col">
        {{#with (lookup navItems 0)}}
          <p class="g-footer__col-title">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}

        {{#with (lookup navItems 1)}}
          <p class="g-footer__col-title g-footer__col-title--secondary">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 2: 使用与顶部导航一致的第三组一级菜单 --}}
      <div class="g-footer__col">
        {{#with (lookup navItems 2)}}
          <p class="g-footer__col-title">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 3: 使用与顶部导航一致的后续一级菜单 --}}
      <div class="g-footer__col">
        {{#with (lookup navItems 3)}}
          <p class="g-footer__col-title">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul>
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}

        {{#with (lookup navItems 4)}}
          <p class="g-footer__col-title g-footer__col-title--secondary">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul>
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}

        {{#with (lookup navItems 5)}}
          <p class="g-footer__col-title g-footer__col-title--secondary">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul>
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}

        {{#with (lookup navItems 6)}}
          <p class="g-footer__col-title g-footer__col-title--secondary">{{title}}</p>
          {{#if children}}
          <ul>
            {{#each children}}
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
            {{/each}}
          </ul>
          {{else}}
          <ul>
            <li><a class="g-footer__navlink" href="{{url}}">{{title}}</a></li>
          </ul>
          {{/if}}
        {{/with}}
      </div>

      {{!-- Column 4: Contact Us + Follow Us（原第5列置于本列底部） --}}
      <div class="g-footer__col g-footer__col--contact">
        <div class="g-footer__contact-section">
          <p class="g-footer__col-title g-footer__col-title--muted">{{footerAboutUs.title}}</p>
          <div class="g-footer__contact-block g-footer__contact-block--emails">
          
            {{#each footerAboutUs.emailItems}}
            <div class="g-footer__contact-email">
              <p class="g-footer__contact-item">{{label}}</p>
              <a href="mailto:{{email}}" class="g-footer__contact-link g-footer__contact-link--email">
                <svg class="g-footer__contact-mail-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{{email}}</span>
              </a>
            </div>
            {{/each}}
          </div>
          <div class="g-footer__contact-block g-footer__contact-block--phone">
            <p class="g-footer__contact-phone-line">
              <span class="g-footer__contact-phone-label">{{footerPhone.label}}</span>
              <a href="tel:{{footerPhone.phone}}" class="g-footer__contact-link g-footer__contact-link--phone">{{footerPhone.phone}}</a>
            </p>
          </div>
        </div>
        <div class="g-footer__follow-section">
          <p class="g-footer__follow-title">{{#if followUs.title}}{{followUs.title}}{{else}}Follow Us{{/if}}</p>
          <div class="g-footer__social">
            {{#if followUs.items}}
              {{#each followUs.items}}
              <a href="{{#if url}}{{url}}{{else}}#{{/if}}" target="_blank" rel="noopener noreferrer" class="g-footer__social-link" aria-label="{{#if title}}{{title}}{{else}}social{{/if}}">
                <img src="{{picUrl}}" alt="{{#if title}}{{title}}{{else}}social{{/if}}" loading="lazy" />
              </a>
              {{/each}}
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </div>
  {{/if}}
  <div class="g-footer__copyright">
    <p>{{footerBeian.content}}</p>
  </div>
</footer>
{{> website/common/inquiry-form-modal}}
  {{> website/common/floating-actions}}
{{> website/common/page-view-tracker}}
{{#unless (eq locale 'cn')}}{{> website/common/member-auth-modal}}{{/unless}}
{{> website/common/cart-drawer}}
{{> website/common/contactus-modal}}
