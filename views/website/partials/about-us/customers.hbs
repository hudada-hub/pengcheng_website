{{!-- 配置 about-us-customers：type 2 数组 pic1Url；title/description；横�?Logo 轮播（无 linkUrl�?--}}
{{#if hasAboutUsCustomers}}
<section
  id="{{aboutUsCustomersSectionId}}"
  class="g-about-us-customers about_customer_warp about_customer_warp--pending g-about-us-anchor-target"
  aria-labelledby="g-about-us-customers-title"
>
  <div class="layout">
    <div class="about_customer_title index_flex">
      <div class="item_text">
        {{#if aboutUsCustomersTitle}}
        <h2 id="g-about-us-customers-title">{{aboutUsCustomersTitle}}</h2>
        {{/if}}
        {{#if aboutUsCustomersIntro}}
        <p>{{aboutUsCustomersIntro}}</p>
        {{/if}}
      </div>
      {{#if (gt (length aboutUsCustomerLogos) 0)}}
      <div
        class="about_customer_btn index_flex"
        id="about-us-customer-nav"
        role="group"
        aria-label="{{#if (eq locale 'cn')}}客户 Logo 轮播{{else}}Customer logos carousel{{/if}}"
      >
        <button type="button" class="swiper_prev" id="about-us-customer-prev" aria-label="{{#if (eq locale 'cn')}}上一组{{else}}Previous{{/if}}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button type="button" class="swiper_next" id="about-us-customer-next" aria-label="{{#if (eq locale 'cn')}}下一组{{else}}Next{{/if}}">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      {{/if}}
    </div>
    {{#if aboutUsCustomerLogos}}
    <div class="about_customer_swiper" id="about-us-customer-swiper">
      <ul class="customer-track" id="about-us-customer-track" role="list">
        {{#each aboutUsCustomerLogos}}
        <li class="about_customer_slide">
          <img src="{{this}}" alt="" loading="lazy" decoding="async" draggable="false" />
        </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  </div>
  <noscript>
    <style>
      .g-about-us-customers.about_customer_warp.about_customer_warp--pending {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</section>
{{/if}}
