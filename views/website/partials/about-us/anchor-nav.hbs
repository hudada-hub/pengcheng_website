{{!-- about-us-anchor：is_array=1；content/title 为文案。linkUrl 可选（区块键或 section id）。若�?6 项且均未�?linkUrl，则固定对应：who �?culture �?history �?partner �?innovative �?map（与常见英文导航一致）。其它条数：按页面区块顺�?auto（含 lead、battery、customers）；仍可�?linkUrl 精确指定 --}}
{{#if hasAboutUsAnchorNav}}
<!-- 桌面端锚点导航 -->
<nav class="g-about-us-anchor g-about-us-anchor--desktop" aria-label="{{#if (eq locale "zh-CN")}}页面锚点{{else}}On this page{{/if}}">
  <div class="container g-about-us-anchor__wrap">
    <ul class="g-about-us-anchor__list">
      {{#each aboutUsAnchorItems}}
      <li class="g-about-us-anchor__item">
        <a
          href="#{{id}}"
          class="g-about-us-anchor__link{{#if @first}} is-active{{/if}}"
          data-about-anchor="{{id}}"
        >{{label}}</a>
      </li>
      {{/each}}
    </ul>
  </div>
</nav>

<!-- 移动端抽屉导航 -->
<div class="g-about-us-anchor-mobile">
  <button class="g-about-us-anchor-mobile__toggle" aria-expanded="false" aria-controls="g-about-us-anchor-mobile-drawer" aria-label="{{#if (eq locale "zh-CN")}}打开页面导航{{else}}Open page navigation{{/if}}">
    <span class="g-about-us-anchor-mobile__toggle-icon"></span>
    <span class="g-about-us-anchor-mobile__toggle-text"></span>
  </button>
  <div class="g-about-us-anchor-mobile__drawer" id="g-about-us-anchor-mobile-drawer">
    <div class="g-about-us-anchor-mobile__drawer-content">
      <nav class="g-about-us-anchor-mobile__nav" aria-label="{{#if (eq locale "zh-CN")}}页面锚点{{else}}On this page{{/if}}">
        <ul class="g-about-us-anchor-mobile__list">
          {{#each aboutUsAnchorItems}}
          <li class="g-about-us-anchor-mobile__item">
            <a
              href="#{{id}}"
              class="g-about-us-anchor-mobile__link{{#if @first}} is-active{{/if}}"
              data-about-anchor="{{id}}"
            >{{label}}</a>
          </li>
          {{/each}}
        </ul>
      </nav>
    </div>
  </div>
</div>
{{/if}}
