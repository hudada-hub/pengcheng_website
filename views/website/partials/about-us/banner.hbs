{{!-- 配置 about-us-banner：bg_pic_url / title（主标题 h1�? description（副标题 h3）；content.title=面包屑首页文案、content.description=当前页文�?--}}
<section
  id="g-about-us-sys-banner"
  class="g-about-us-banner about_sys_warp about_sys_warp--pending"
  aria-labelledby="g-about-us-banner-title"
>
  <div class="about_sys_banner">
    {{#if bannerImageUrl}}
    <img
      src="{{bannerImageUrl}}"
      alt=""
      class="about_sys_banner__img"
      loading="eager"
    />
    {{else}}
    <div class="about_sys_banner__placeholder" role="img" aria-hidden="true"></div>
    {{/if}}
    <div class="about_sys_banner__overlay" aria-hidden="true"></div>
  </div>
  <div class="about_sys_main">
    <div class="layout">
      <div class="item_text">
        {{#if aboutUsBannerSubtitle}}
        <h3 class="g-about-us-banner__kicker">{{aboutUsBannerSubtitle}}</h3>
        {{/if}}
        <h1 id="g-about-us-banner-title" class="g-about-us-banner__title">{{aboutUsBannerTitle}}</h1>
      </div>
      <nav class="about_sys_nav_wrap" aria-label="{{#if (eq locale 'zh-CN')}}面包屑{{else}}Breadcrumb{{/if}}">
        <ul class="about_sys_nav">
          <li>
            <a href="{{#if basePath}}{{basePath}}{{else}}/{{/if}}" class="about_sys_nav__link about_sys_nav__link--home">{{aboutUsBreadcrumbHomeLabel}}</a>
          </li>
          <li>
            <span class="about_sys_nav__current" aria-current="page">{{aboutUsBreadcrumbCurrentLabel}}</span>
          </li>
        </ul>
      </nav>
    </div>
  </div>
  <noscript>
    <style>
      .g-about-us-banner.about_sys_warp.about_sys_warp--pending {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</section>
