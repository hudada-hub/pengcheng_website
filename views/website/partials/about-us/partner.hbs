{{!--
  й…ҚзҪ® keyпјҡabout-us-partnerпјҲtype 12 зӯүпјү
  иЎЁеӨҙпјҡtitle=е·Ұж Ҹе°Ҹж ҮйўҳпјҲеҰ?Our StrongпјүгҖҒdescription=е·Ұж ҸеӨ§ж ҮйўҳпјҲеҰ?PartnerпјүгҖҒbg_pic_url=еҸідҫ§дё»еӣҫ
  content JSONпјҡtitle=еҗҲдҪңж–№еҗҚпјҲCATLпјүгҖҒcontent=еҸідҫ§дёӢжІҝж ҮиҜӯпјҲеҰӮ GlobalвҖ?NO.1пјүгҖҒdescription=и“қжЎҶеҶ…еӨҡж®өжӯЈж–ҮпјҲ\n\n еҲҶж®өпјүгҖҒpic1Url=и“қжЎҶеҶ?logoпј?  type 12 еҸҰжңүпјҡsubtitle=еҸідҫ§зҒ°жқЎеӨ§еӯ—пјҲеҰӮ InversorпјүпјӣsubDescription еҸҜдҪңеҸ еӯ—пјҲжҲ–з”?slideWatermark жҢҮе®ҡпјүпјӣдәҰе…је®?slideTitle/itemTitle
--}}
{{#if hasAboutUsPartner}}
<section
  id="{{aboutUsPartnerSectionId}}"
  class="g-about-us-partner about_partner_warp about_partner_warp--pending about_scrool g-about-us-anchor-target"
  aria-labelledby="g-about-us-partner-heading"
>
  <div class="about_partner_main">
    <div class="about_partner_box">
      <div class="about_partner_item">
        {{#if aboutUsPartnerHeadlineSmall}}
        <h3>{{aboutUsPartnerHeadlineSmall}}</h3>
        {{/if}}
        {{#if aboutUsPartnerHeadlineLarge}}
        <h2 id="g-about-us-partner-heading">{{aboutUsPartnerHeadlineLarge}}</h2>
        {{/if}}
      </div>
      <div class="about_partner_text">
        <h2 style="display: flex;align-items:center;">
          {{#if aboutUsPartnerBoxLogoUrl}}
          <img src="{{aboutUsPartnerBoxLogoUrl}}" alt="{{aboutUsPartnerName}}" loading="lazy" decoding="async" />
          {{/if}}
          <span aria-hidden="true"></span>
         <div style="width:500px;"> {{#if aboutUsPartnerName}}{{aboutUsPartnerName}}{{/if}}</div>
        </h2>
        {{#if aboutUsPartnerBodyParagraphs}}
        <div class="item_text">
          {{#each aboutUsPartnerBodyParagraphs}}
          <p>{{this}}</p>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </div>
    <div class="about_partner_slide">
      {{#if aboutUsPartnerSlideTitle}}
      <div class="item_title">
        <h2>{{aboutUsPartnerSlideTitle}}</h2>
      </div>
      {{/if}}
      {{#if aboutUsPartnerHeroImageUrl}}
      <div class="item_img">
        <img
          src="{{aboutUsPartnerHeroImageUrl}}"
          alt="{{#if aboutUsPartnerName}}{{aboutUsPartnerName}}{{else}}Partner{{/if}}"
          loading="lazy"
          decoding="async"
        />
      </div>
      {{/if}}
      {{#if aboutUsPartnerTagline}}
      <div class="item_text">
        {{#if aboutUsPartnerSlideWatermark}}
        <h3>{{aboutUsPartnerSlideWatermark}}</h3>
        {{else if aboutUsPartnerName}}
        <h3>{{aboutUsPartnerName}}</h3>
        {{/if}}
        <p>{{aboutUsPartnerTagline}}</p>
      </div>
      {{else}}
      {{#if aboutUsPartnerSlideWatermark}}
      <div class="item_text item_text--watermark-only">
        <h3>{{aboutUsPartnerSlideWatermark}}</h3>
      </div>
      {{else if aboutUsPartnerName}}
      <div class="item_text item_text--watermark-only">
        <h3>{{aboutUsPartnerName}}</h3>
      </div>
      {{/if}}
      {{/if}}
    </div>
  </div>
  <noscript>
    <style>
      .g-about-us-partner.about_partner_warp.about_partner_warp--pending {
        opacity: 1 !important;
        transform: none !important;
      }
    </style>
  </noscript>
</section>
{{/if}}
