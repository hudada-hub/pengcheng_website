<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  {{#if sharePageUrl}}<link rel="canonical" href="{{sharePageUrl}}">{{/if}}
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/bootstrap-grid.css">
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/grid.css">
  {{#if (eq locale 'cn')}}
  <link rel="stylesheet" href="/css/cn/common-cn.css">
  <link rel="stylesheet" href="/css/cn/news-cn.css">
  {{else}}
  <link rel="stylesheet" href="/css/global/common-global.css">
  <link rel="stylesheet" href="/css/global/news-global.css">
  {{/if}}
  {{#if (ne locale 'cn')}}<link rel="stylesheet" href="/css/exo.css">{{/if}}
  <script src="/js/iconify-icon.min.js" defer></script>
</head>
<body class="g-news-detail-page">
  {{> website/common/nav-drawer}}
  {{> website/common/header}}

  <main class="g-main">
    <section class="g-news-banner" aria-label="{{news.title}}">
      <div
        class="g-news-banner__bg{{#if news.thumbUrl}} g-news-banner__bg--image{{/if}}"
        {{#if news.thumbUrl}}style="--g-news-banner-image: url('{{{news.thumbUrl}}}');"{{/if}}
        aria-hidden="true"
      ></div>
      <div class="g-news-banner__inner">
      </div>
    </section>

    <div class="g-news-detail-main">
      <div class="container g-news-detail-container">
        <div
          data-share-root
          class="g-news-detail-wrap"
          data-share-url="{{sharePageUrl}}"
          data-msg-copied='{{#if (eq locale "zh-CN")}}链接已复制{{else}}Link copied{{/if}}'
          data-msg-copy-fail='{{#if (eq locale "zh-CN")}}复制失败{{else}}Copy failed{{/if}}'
        >
          <div class="g-case-detail-layout__inner">
            <article class="g-news-detail">
              <div class="g-news-detail__content">
                <h1 class="g-news-detail__title">{{news.title}}</h1>
                {{#if publishAtFormatted}}
                <div class="g-news-detail__meta">{{publishAtFormatted}}</div>
                {{/if}}
                {{{news.content}}}
              </div>
            </article>

            {{!-- 工具栏（桌面侧边 + 移动底栏�? 分享弹窗 --}}
            {{> website/common/detail-nav-toolbar prevItem=newsPrev nextItem=newsNext listUrl=listUrl}}
          </div>
        </div>
      </div>
    </div>

    {{> website/common/footer}}
  </main>

  <script src="/js/qrcode.min.js" defer></script>
  <script src="/js/case-detail-share.js" defer></script>
  <script>
    (function () {
      var nav = document.querySelector('.g-news-detail-page .pc-nav');
      if (!nav) return;
      function onScroll() {
        nav.classList.toggle('nav-scrolled', window.scrollY > 10);
      }
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
</body>
</html>
