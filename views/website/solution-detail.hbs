<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/bootstrap-grid.css">
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/grid.css">
  {{#if (eq locale 'cn')}}
  <link rel="stylesheet" href="/css/cn/common-cn.css">
  <link rel="stylesheet" href="/css/cn/products-cn.css">
  <link rel="stylesheet" href="/css/cn/solutions-cn.css">
  <link rel="stylesheet" href="/css/cn/solution-detail-cn.css">
  {{else}}
  <link rel="stylesheet" href="/css/global/common-global.css">
  <link rel="stylesheet" href="/css/global/products-global.css">
  <link rel="stylesheet" href="/css/global/solutions-global.css">
  <link rel="stylesheet" href="/css/global/solution-detail-global.css">
  {{/if}}
  <link rel="stylesheet" href="/css/other/animate.min.css">
  
  {{#if (ne locale 'cn')}}
  <link rel="stylesheet" href="/css/exo.css">
  {{/if}}
  <script src="/js/iconify-icon.min.js" defer></script>
</head>
<body class="g-products-page g-solution-detail-page">
  {{> website/common/nav-drawer}}
  {{> website/common/header}}

  <main class="g-main">
    {{> website/solutions/solution-detail-hero}}
    
    <div class="g-products-layout g-solution-detail-layout">
      <div class="container g-products-layout__inner">
        {{> website/solutions/solution-detail-body}}
        
      </div>
         
    </div>
    <div style="background-color: #f5f5f7;">
  <div class="container" >
     {{> website/common/related-products relatedProducts=relatedProducts hasRelatedProducts=hasRelatedProducts locale=locale relatedProductsConfig=relatedProductsConfig}}
  </div>
    </div>


    {{> website/common/footer}}
  </main>

  <script src="/js/wow.min.js"></script>
  <script>
    (function () {
      if (typeof WOW === 'function') {
        window.wow = new WOW({ boxClass: 'wow', animateClass: 'animated', offset: 0, mobile: true, live: true });
        window.wow.init();
      }
    })();
  </script>
</body>
</html>
