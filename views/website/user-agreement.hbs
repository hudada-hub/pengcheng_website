<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  <link rel="icon" type="image/png" href="/images/icon.png">
  <style>
    :root { color-scheme: light; }
    body { margin: 0; font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #1a1a1a; background: #fff; }
    .g-user-agreement { max-width: 52rem; margin: 0 auto; padding: 1.5rem clamp(1rem, 4vw, 2rem) 3rem; box-sizing: border-box; }
    .g-user-agreement :first-child { margin-top: 0; }
    .g-user-agreement img { max-width: 100%; height: auto; }
  </style>
</head>
<body class="g-user-agreement-page">
  <main class="g-user-agreement">
    {{{userAgreementHtml}}}
  </main>
</body>
</html>
