<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  <link rel="icon" type="image/png" href="/images/icon.png">
    <link rel="stylesheet" href="/css/bootstrap-grid.css" >
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/grid.css">
  <link rel="stylesheet" href="/js/swiper/swiper-bundle.min.css" />
  {{#if (eq locale 'cn')}}
  <link rel="stylesheet" href="/css/cn/common-cn.css">
  <link rel="stylesheet" href="/css/cn/home-cn.css">
  {{else}}
  <link rel="stylesheet" href="/css/global/common-global.css">
  <link rel="stylesheet" href="/css/global/home-global.css">
  {{/if}}
  <link rel="stylesheet" href="/css/other/animate.min.css">
  

  <script src="/js/swiper/swiper-bundle.min.js"></script>
  {{#if (eq locale 'cn')}}
  <link rel="stylesheet" href="/css/source-han-sans.css">
  {{else}}
  <link rel="stylesheet" href="/css/exo.css">
  {{/if}}
</head>
<body class="g-home-page">
  {{> website/common/nav-drawer}}
  {{> website/common/header}}

  <main class="g-main">
    {{> website/home/hero}}
    {{> website/home/stats}}
    {{> website/home/customers}}
    {{> website/home/business-areas}}
    {{> website/home/about-us}}
    {{> website/home/news-events}}
    {{> website/common/contactus}}
    {{> website/common/footer}}
  </main>
  <script src="/js/wow.min.js"></script>
  <script src="/js/gsap/gsap.min.js" defer></script>
  <script src="/js/gsap/ScrollTrigger.min.js" defer></script>
  <script src="/js/home-stats-counter.js" defer></script>
  <script src="/js/home-customers-carousel.js" defer></script>
  <script>
    (function () {
      var nav = document.querySelector('.g-home-page .pc-nav');
      if (!nav) return;
      function onScroll() {
        nav.classList.toggle('nav-scrolled', window.scrollY > 10);
      }
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Video Modal
      var cirplay = document.querySelector('.g-about__cirplay[data-video-url]');
      var modal = document.getElementById('aboutVideoModal');
      if (cirplay && modal) {
        var overlay = modal.querySelector('.g-video-modal__overlay');
        var closeBtn = modal.querySelector('.g-video-modal__close');
        var video = modal.querySelector('.g-video-modal__video');

        function openModal() {
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
          if (video) video.play();
        }

        function closeModal() {
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          if (video) {
            video.pause();
            video.currentTime = 0;
          }
        }

        cirplay.addEventListener('click', openModal);
        cirplay.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openModal();
          }
        });

        if (overlay) overlay.addEventListener('click', closeModal);
        if (closeBtn) closeBtn.addEventListener('click', closeModal);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
            closeModal();
          }
        });
      }
    })();
  </script>
</body>
</html>
