<!DOCTYPE html>
<html lang="{{locale}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  {{#if description}}<meta name="description" content="{{description}}">{{/if}}
  {{#if keywords}}<meta name="keywords" content="{{keywords}}">{{/if}}
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/bootstrap-grid.css">
  <link rel="stylesheet" href="/css/common.css">
  <link rel="stylesheet" href="/css/grid.css">
  <link rel="stylesheet" href="/css/global/common-global.css">
  <link rel="stylesheet" href="/css/global/products-global.css">
  <link rel="stylesheet" href="/css/global/warranty-global.css">
  
  <link rel="stylesheet" href="/css/exo.css">
</head>
<body class="g-warranty-page">
  {{> website/common/nav-drawer}}
  {{> website/common/header}}

  <main class="g-main g-warranty-main">
    {{#if hasBanner}}
    {{> website/service/banner}}
    {{/if}}
    <div class="container g-warranty-layout">
      <div class="g-warranty-sheet">
        <h1 class="g-warranty-title">{{pageHeading}}</h1>
        {{#if hasWarrantyBody}}
        <div class="g-warranty-prose">
          {{{warrantyHtml}}}
        </div>
        {{/if}}
      </div>
    </div>
    {{> website/common/footer}}
  </main>

  <script>
    (function () {
      var nav = document.querySelector('.g-warranty-page .pc-nav');
      if (!nav) return;
      function onScroll() {
        nav.classList.toggle('nav-scrolled', window.scrollY > 10);
      }
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    })();
  </script>
</body>
</html>
