<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 鹏成后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <link rel="stylesheet" href="/css/other/wangeditor.css">
  <script src="/js/iconify-icon.min.js"></script>
  <script src="/js/wangeditor.js"></script>
  <script src="/js/admin-file-manager.js"></script>
  <script src="/js/admin-richtext.js"></script>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
        <div>
          <h1 style="margin:0;">{{title}}</h1>
          <div style="font-size:var(--font-size-sm);color:var(--admin-text-muted);margin:0.25rem 0;">排序数字越大，在列表中显示越靠前</div>
        </div>
        <div class="admin-page-toolbar__row">
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);">语言</label>
          <select id="newsLangId" style="max-width:220px;">
            <option value="all" {{#if (eq selectedLangId '')}}selected{{/if}}>全部</option>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedLangId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);">新闻分类</label>
          <select id="newsCategoryId" style="max-width:200px;">
            <option value="">全部</option>
            {{#each categories}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedCategoryIdNum)}}selected{{/if}}>{{this.name}}{{#if this.lang}} ({{this.lang.code}}){{/if}}</option>
            {{/each}}
          </select>
          <button type="button" class="btn btn-primary" id="btnNewsAdd"><iconify-icon icon="mdi:plus"></iconify-icon> 新增</button>
          <button type="button" class="btn btn-secondary" id="btnNewsBatchDelete" style="margin-left:0.25rem;"><iconify-icon icon="mdi:delete-sweep"></iconify-icon> 批量删除</button>
          <button type="button" class="btn btn-primary" id="btnNewsBatchTranslate" style="margin-left:0.25rem;" disabled><iconify-icon icon="mdi:translate"></iconify-icon> 批量翻译</button>
        </div>
      </div>
      <form id="newsBatchDeleteForm" method="post" action="/admin/news/batch-delete" style="display:none;">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
      </form>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:2.5rem;">
                <input type="checkbox" id="newsSelectAll" title="全选" aria-label="全选">
              </th>
              <th>ID</th>
              <th>缩略图</th>
              <th>标题</th>
              <th id="newsLangTh" style="{{#if (eq selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">语言</th>
              <th>发布时间</th>
              <th style="width:100px;">状态</th>
              <th style="width:100px;">置顶</th>
              <th>排序</th>
              <th style="width:260px;">操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each newsList}}
            <tr>
              <td><input type="checkbox" class="news-row-cb" value="{{this.id}}" aria-label="选择"></td>
              <td>{{this.id}}</td>
              <td>{{#if this.thumbUrl}}<img src="{{this.thumbUrl}}" data-image-preview="{{this.thumbUrl}}" alt="" class="news-list-thumb admin-thumb-clickable" style="max-width:60px;max-height:60px;object-fit:cover;">{{else}}-{{/if}}</td>
              <td>{{this.title}}</td>
              <td class="news-lang-cell" style="{{#if (eq ../selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">{{#if this.lang}}{{this.lang.name}} ({{this.lang.code}}){{else}}-{{/if}}</td>
              <td>{{this.publishAtFormatted}}</td>
              <td style="width:100px;">{{#if (eq this.status 1)}}<span class="status-normal">正常</span>{{else}}<span class="status-hidden">隐藏</span>{{/if}}</td>
              <td style="width:100px;">{{#if (eq this.isTop 1)}}<span class="status-top" title="已置顶">🔝 置顶</span>{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td>
                <input type="number" class="news-sort-input" data-id="{{this.id}}" value="{{this.sort}}" min="0" style="width:60px;">
              </td>
              <td class="actions">
                <a href="#" class="news-edit-link" data-id="{{this.id}}">编辑</a>
                <form method="post" action="/admin/news/toggle-top/{{this.id}}" style="display:inline;">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <button type="submit" class="btn-link">{{#if (eq this.isTop 1)}}取消置顶{{else}}置顶{{/if}}</button>
                </form>
                <a href="#" class="news-translate-link" data-id="{{this.id}}">一键翻译</a>
                <button type="button" class="btn-link news-delete-btn" data-id="{{this.id}}" data-popconfirm="确定删除该新闻吗？">删除</button>
              </td>
            </tr>
            {{else}}
            <tr><td colspan="10" style="text-align:center;color:var(--admin-text-muted);">暂无数据</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{#if pagination}}
      <div class="admin-pagination-wrap" style="margin-top:1rem;">
        {{> admin/pagination currentPage=pagination.currentPage totalPages=pagination.totalPages baseUrl=pagination.baseUrl}}
      </div>
      {{/if}}
    </main>
  </div>
  {{> admin/modal-form title="新闻"}}
  {{> admin/file-manager-modal}}
  {{> admin/translate-modal idPrefix="newsTranslate"}}
  {{!-- 批量翻译弹窗：勾选目标语言后提交 --}}
  <div id="newsBatchTranslateModalOverlay" class="admin-modal-overlay admin-translate-modal-overlay" aria-hidden="true">
    <div class="admin-modal-dialog admin-translate-modal" role="dialog" aria-modal="true" aria-labelledby="newsBatchTranslateModalTitle">
      <div class="admin-translate-modal-header">
        <h2 class="admin-translate-modal-title" id="newsBatchTranslateModalTitle">批量翻译</h2>
        <button type="button" class="admin-translate-modal-close" id="newsBatchTranslateModalClose" aria-label="关闭">
          <iconify-icon icon="mdi:close"></iconify-icon>
        </button>
      </div>
      <div class="admin-translate-modal-body" id="newsBatchTranslateModalBody">
        <p style="margin-bottom:0.5rem;">选择要翻译成的语言（可多选）：</p>
        <div style="max-height:200px;overflow:auto;">
          {{#each langs}}
          <label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="news-batch-translate-lang-cb" value="{{this.id}}"> {{this.name}} ({{this.code}})</label>
          {{/each}}
        </div>
      </div>
      <div class="admin-translate-modal-footer">
        <div class="admin-translate-modal-actions">
          <button type="button" class="btn btn-secondary" id="newsBatchTranslateModalCancel">取消</button>
          <button type="button" class="btn btn-primary" id="newsBatchTranslateModalSubmit">开始翻译</button>
        </div>
      </div>
    </div>
  </div>
  {{> admin/image-preview-modal}}
  {{> admin/confirm-modal}}
  <script>
    (function () {
      var csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : '';
      var formOverlay = document.getElementById('adminModalFormOverlay');
      var formModalBody = document.querySelector('.admin-modal-form-body');
      var formModalTitle = document.getElementById('adminModalFormTitle');
      var newsEditorInstance = null;

      function initNewsEditorInModal(container) {
        if (!container || !window.AdminRichText || !window.AdminRichText.init) return;
        if (newsEditorInstance && typeof newsEditorInstance.destroy === 'function') newsEditorInstance.destroy();
        newsEditorInstance = window.AdminRichText.init({
          root: container,
          editorSelector: '#news-editor-container',
          toolbarSelector: '#news-toolbar-container',
          textareaSelector: '#newsContentTa',
          placeholder: '请输入正文...',
        });
      }

      function openFormModal(titleText, formUrl) {
        if (newsEditorInstance && typeof newsEditorInstance.destroy === 'function') newsEditorInstance.destroy();
        newsEditorInstance = null;
        if (!formOverlay || !formModalBody) return;
        formModalTitle.textContent = titleText;
        formModalBody.innerHTML = '<p style="text-align:center;color:var(--admin-text-muted);">加载中...</p>';
        formOverlay.classList.add('open');
        formOverlay.setAttribute('aria-hidden', 'false');
        fetch(formUrl, { credentials: 'same-origin' })
          .then(function (r) { return r.text(); })
          .then(function (html) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');
            var frag = doc.getElementById('admin-form-fragment');
            formModalBody.innerHTML = frag ? frag.innerHTML : html;
            var _form = formModalBody.querySelector('form');
            if (_form) { var _inp = document.createElement('input'); _inp.type = 'hidden'; _inp.name = 'returnUrl'; _inp.value = window.location.href; _form.appendChild(_inp); }
            var cancelBtn = formModalBody.querySelector('.admin-modal-form-cancel');
            if (cancelBtn) cancelBtn.onclick = closeFormModal;
            var form = formModalBody.querySelector('#newsEditForm');
            if (form) {
              form.onsubmit = function (e) {
                var cs = formModalBody.querySelector('#newsFormCategoryId');
                if (cs && !cs.value) {
                  if (e && e.preventDefault) e.preventDefault();
                  alert('请选择「所属新闻分类」。若当前语言下没有可选分类，请先到「新闻分类」管理中添加。');
                  return false;
                }
                if (newsEditorInstance && newsEditorInstance.sync) newsEditorInstance.sync();
              };
            }
            initNewsEditorInModal(formModalBody);
            var titleEl = formModalBody.querySelector('#newsTitle');
            var metaEl = formModalBody.querySelector('#newsMetaTitle');
            if (titleEl && metaEl) {
              if (!metaEl.value && titleEl.value) metaEl.value = titleEl.value;
              titleEl.addEventListener('input', function () { if (!metaEl.dataset.edited) metaEl.value = titleEl.value; });
              metaEl.addEventListener('input', function () { metaEl.dataset.edited = '1'; });
            }
            var thumbInput = formModalBody.querySelector('#newsThumbUrl');
            var thumbPreview = formModalBody.querySelector('#newsThumbPreview');
            var thumbBtn = formModalBody.querySelector('#newsBtnPickThumb');
            if (thumbBtn && thumbInput && window.AdminFileManager && window.AdminFileManager.open) {
              thumbBtn.onclick = function () {
                window.AdminFileManager.open({ type: 'image', targetInput: thumbInput, targetPreview: thumbPreview });
              };
            }
            var catJsonEl = formModalBody.querySelector('#newsCategoryOptionsJson');
            var catSelect = formModalBody.querySelector('#newsFormCategoryId');
            var langSelectForm = formModalBody.querySelector('#newsFormLangId');
            if (catJsonEl && catSelect && langSelectForm && form) {
              var allCatOpts = [];
              try { allCatOpts = JSON.parse(catJsonEl.textContent || '[]'); } catch (e) { allCatOpts = []; }
              var initialCategoryId = form.getAttribute('data-initial-category-id') || '';
              function syncNewsFormCategories(isLangChange) {
                var lid = parseInt(langSelectForm.value, 10);
                if (!Number.isFinite(lid)) return;
                var prev = catSelect.value;
                var forLang = allCatOpts.filter(function (o) { return o.langId === lid; });
                catSelect.innerHTML = '';
                forLang.forEach(function (o) {
                  var opt = document.createElement('option');
                  opt.value = String(o.id);
                  opt.textContent = o.name;
                  catSelect.appendChild(opt);
                });
                var hint = formModalBody.querySelector('#newsCategoryEmptyHint');
                if (hint) hint.style.display = forLang.length ? 'none' : 'block';
                if (forLang.length) {
                  var pick = '';
                  if (!isLangChange && initialCategoryId && forLang.some(function (o) { return String(o.id) === initialCategoryId; })) {
                    pick = initialCategoryId;
                  } else if (prev && forLang.some(function (o) { return String(o.id) === prev; })) {
                    pick = prev;
                  } else {
                    pick = String(forLang[0].id);
                  }
                  catSelect.value = pick;
                } else {
                  var emptyOpt = document.createElement('option');
                  emptyOpt.value = '';
                  emptyOpt.textContent = '（当前语言下暂无新闻分类）';
                  catSelect.appendChild(emptyOpt);
                  catSelect.value = '';
                }
              }
              syncNewsFormCategories(false);
              langSelectForm.addEventListener('change', function () { syncNewsFormCategories(true); });
            }
          })
          .catch(function () { formModalBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }
      function closeFormModal() {
        if (newsEditorInstance && typeof newsEditorInstance.destroy === 'function') newsEditorInstance.destroy();
        newsEditorInstance = null;
        if (formOverlay) { formOverlay.classList.remove('open'); formOverlay.setAttribute('aria-hidden', 'true'); }
      }
      document.getElementById('adminModalFormClose').onclick = closeFormModal;
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && formOverlay && formOverlay.classList.contains('open')) closeFormModal(); });
      document.getElementById('btnNewsAdd').onclick = function () {
        var lid = document.getElementById('newsLangId') && document.getElementById('newsLangId').value;
        var url = '/admin/news/edit?modal=1';
        if (lid && lid !== 'all') url += '&langId=' + encodeURIComponent(lid);
        openFormModal('新增新闻', url);
      };
      document.querySelectorAll('.news-edit-link').forEach(function (a) {
        a.onclick = function (e) { e.preventDefault(); var id = a.getAttribute('data-id'); if (id) openFormModal('编辑新闻', '/admin/news/edit/' + id + '?modal=1'); };
      });

      function buildNewsListUrl(opts) {
        var langId = opts && opts.langId !== undefined ? opts.langId : (document.getElementById('newsLangId') && document.getElementById('newsLangId').value) || '';
        var categoryId = opts && opts.categoryId !== undefined ? opts.categoryId : (document.getElementById('newsCategoryId') && document.getElementById('newsCategoryId').value) || '';
        var page = opts && opts.page !== undefined ? opts.page : null;
        var pageSize = opts && opts.pageSize !== undefined ? opts.pageSize : ({{#if pagination}}{{pagination.pageSize}}{{else}}15{{/if}});
        var params = [];
        if (langId && langId !== 'all') params.push('langId=' + encodeURIComponent(langId));
        else if (langId === 'all') params.push('langId=all');
        if (categoryId) params.push('categoryId=' + encodeURIComponent(categoryId));
        params.push('pageSize=' + encodeURIComponent(String(pageSize)));
        if (page != null && page > 1) params.push('page=' + encodeURIComponent(String(page)));
        return '/admin/news' + (params.length ? '?' + params.join('&') : '');
      }
      var langSelect = document.getElementById('newsLangId');
      if (langSelect) langSelect.onchange = function () {
        window.location.href = buildNewsListUrl({ langId: langSelect.value, categoryId: '', page: 1 });
      };
      var categorySelect = document.getElementById('newsCategoryId');
      if (categorySelect) categorySelect.onchange = function () {
        window.location.href = buildNewsListUrl({ categoryId: categorySelect.value, page: 1 });
      };
      var paginationNav = document.querySelector('.admin-pagination');
      if (paginationNav) {
        var baseUrl = paginationNav.getAttribute('data-base-url');
        var cur = parseInt(paginationNav.getAttribute('data-current'), 10) || 1;
        var total = parseInt(paginationNav.getAttribute('data-total'), 10) || 1;
        var prevBtn = paginationNav.querySelector('.admin-pagination-prev');
        var nextBtn = paginationNav.querySelector('.admin-pagination-next');
        if (prevBtn && baseUrl) prevBtn.onclick = function () { if (cur > 1) window.location.href = baseUrl + '&page=' + (cur - 1); };
        if (nextBtn && baseUrl) nextBtn.onclick = function () { if (cur < total) window.location.href = baseUrl + '&page=' + (cur + 1); };
      }
      var selectAllCb = document.getElementById('newsSelectAll');
      var rowCbs = document.querySelectorAll('.news-row-cb');
      if (selectAllCb && rowCbs.length) {
        selectAllCb.onchange = function () {
          rowCbs.forEach(function (cb) { cb.checked = selectAllCb.checked; });
        };
      }
      // 批量删除 / 批量翻译：勾选控制
      var batchDeleteBtn = document.getElementById('btnNewsBatchDelete');
      var btnBatchTranslate = document.getElementById('btnNewsBatchTranslate');
      function syncBatchButtons() {
        var checked = document.querySelectorAll('.news-row-cb:checked');
        if (btnBatchTranslate) btnBatchTranslate.disabled = checked.length === 0;
      }
      rowCbs.forEach(function (cb) { cb.addEventListener('change', syncBatchButtons); });
      if (selectAllCb) selectAllCb.addEventListener('change', syncBatchButtons);
      syncBatchButtons();
      var batchDeleteForm = document.getElementById('newsBatchDeleteForm');
      if (batchDeleteBtn && batchDeleteForm) {
        batchDeleteBtn.onclick = function () {
          var checked = document.querySelectorAll('.news-row-cb:checked');
          var ids = [];
          checked.forEach(function (cb) { ids.push(cb.value); });
          if (!ids.length) { alert('请先勾选要删除的新闻'); return; }
          var msg = '确定删除所选 ' + ids.length + ' 条新闻吗？';
          var doSubmit = function () {
            batchDeleteForm.innerHTML = '<input type="hidden" name="_csrf" value="' + (csrfToken || '') + '">';
            ids.forEach(function (id) {
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'ids';
              input.value = id;
              batchDeleteForm.appendChild(input);
            });
            batchDeleteForm.submit();
          };
          if (window.showConfirmModal) {
            window.showConfirmModal(msg, doSubmit);
          } else if (confirm(msg)) {
            doSubmit();
          }
        };
      }
      // 批量翻译弹窗
      var batchTranslateOverlay = document.getElementById('newsBatchTranslateModalOverlay');
      function openBatchTranslateModal() {
        var ids = Array.prototype.slice.call(document.querySelectorAll('.news-row-cb:checked')).map(function (cb) { return parseInt(cb.value, 10); }).filter(function (n) { return !isNaN(n); });
        if (!ids.length) { alert('请先勾选要翻译的新闻'); return; }
        if (!batchTranslateOverlay) return;
        batchTranslateOverlay.classList.add('open');
        batchTranslateOverlay.setAttribute('aria-hidden', 'false');
        batchTranslateOverlay.dataset.sourceIds = ids.join(',');
      }
      function closeBatchTranslateModal() {
        if (batchTranslateOverlay) { batchTranslateOverlay.classList.remove('open'); batchTranslateOverlay.setAttribute('aria-hidden', 'true'); }
      }
      if (btnBatchTranslate) btnBatchTranslate.onclick = openBatchTranslateModal;
      document.getElementById('newsBatchTranslateModalClose').onclick = closeBatchTranslateModal;
      document.getElementById('newsBatchTranslateModalCancel').onclick = closeBatchTranslateModal;
      if (batchTranslateOverlay) batchTranslateOverlay.onclick = function (e) { if (e.target === batchTranslateOverlay) closeBatchTranslateModal(); };
      document.getElementById('newsBatchTranslateModalSubmit').onclick = function () {
        var langCbs = document.querySelectorAll('.news-batch-translate-lang-cb:checked');
        var targetLangIds = [];
        langCbs.forEach(function (cb) { targetLangIds.push(parseInt(cb.value, 10)); });
        if (!targetLangIds.length) { alert('请至少选择一种目标语言'); return; }
        var sourceIdsStr = batchTranslateOverlay && batchTranslateOverlay.dataset.sourceIds ? batchTranslateOverlay.dataset.sourceIds : '';
        var sourceIds = sourceIdsStr.split(',').map(function (s) { return parseInt(s.trim(), 10); }).filter(function (n) { return !isNaN(n) && n > 0; });
        if (!sourceIds.length) { alert('未找到要翻译的新闻'); return; }
        var btn = document.getElementById('newsBatchTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/news/translate-batch', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken },
          body: JSON.stringify({ _csrf: csrfToken, sourceIds: sourceIds, targetLangIds: targetLangIds })
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeBatchTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };

      var translateOverlay = document.getElementById('newsTranslateModalOverlay');
      var translateBody = document.getElementById('newsTranslateModalBody');
      var translateSourceId = 0;
      function escapeHtml(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;').replace(/'/g, '&#039;'); }
      function loadTranslateLangs() {
        if (!translateBody || !translateSourceId) return;
        var retranslateEl = document.getElementById('newsTranslateRetranslateCb');
        var retranslate = retranslateEl ? retranslateEl.checked : false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        var url = '/admin/api/news/missing-langs?id=' + encodeURIComponent(translateSourceId);
        if (retranslate) url += '&retranslate=1';
        fetch(url, { credentials: 'same-origin' }).then(function (r) { return r.json(); })
          .then(function (langs) {
            if (!langs || !langs.length) { translateBody.innerHTML = '<p class="admin-text-muted">' + (retranslate ? '暂无其他语言。' : '暂无缺失语言。') + '</p>'; return; }
            var html = '<p style="margin-bottom:0.5rem;">选择要翻译成的语言：</p><button type="button" class="btn btn-secondary btn-sm" id="newsTranslateSelectAll">一键补充缺失的所有语言</button><div style="margin-top:0.75rem;max-height:200px;overflow:auto;">';
            langs.forEach(function (l) { html += '<label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="news-translate-cb" value="' + escapeHtml(String(l.id)) + '"> ' + escapeHtml(l.name) + ' (' + escapeHtml(l.code) + ')</label>'; });
            html += '</div>';
            translateBody.innerHTML = html;
            var selAll = document.getElementById('newsTranslateSelectAll');
            if (selAll) selAll.onclick = function () { translateBody.querySelectorAll('.news-translate-cb').forEach(function (cb) { cb.checked = true; }); };
          }).catch(function () { translateBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }
      function openTranslateModal(id) {
        translateSourceId = id;
        if (!translateOverlay || !translateBody) return;
        var cb = document.getElementById('newsTranslateRetranslateCb');
        if (cb) cb.checked = false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        translateOverlay.classList.add('open');
        translateOverlay.setAttribute('aria-hidden', 'false');
        loadTranslateLangs();
      }
      function closeTranslateModal() { if (translateOverlay) { translateOverlay.classList.remove('open'); translateOverlay.setAttribute('aria-hidden', 'true'); } }
      document.getElementById('newsTranslateModalClose').onclick = closeTranslateModal;
      document.getElementById('newsTranslateModalCancel').onclick = closeTranslateModal;
      if (translateOverlay) translateOverlay.onclick = function (e) { if (e.target === translateOverlay) closeTranslateModal(); };
      var retranslateCb = document.getElementById('newsTranslateRetranslateCb');
      if (retranslateCb) retranslateCb.onchange = loadTranslateLangs;
      document.querySelectorAll('.news-translate-link').forEach(function (a) {
        a.onclick = function (e) { e.preventDefault(); var id = a.getAttribute('data-id'); if (id) openTranslateModal(parseInt(id, 10)); };
      });
      document.getElementById('newsTranslateModalSubmit').onclick = function () {
        var cbs = document.querySelectorAll('#newsTranslateModalBody .news-translate-cb:checked');
        var ids = [];
        cbs.forEach(function (cb) { ids.push(parseInt(cb.value, 10)); });
        if (!ids.length) { alert('请至少选择一种语言'); return; }
        var btn = document.getElementById('newsTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/news/translate', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken }, body: JSON.stringify({ _csrf: csrfToken, sourceId: translateSourceId, targetLangIds: ids }) })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };

      // 单个删除功能（AJAX）
      document.querySelectorAll('.news-delete-btn').forEach(function (btn) {
        btn.onclick = function () {
          var id = btn.getAttribute('data-id');
          var msg = btn.getAttribute('data-popconfirm') || '确定删除吗？';
          var doDelete = function () {
            fetch('/admin/news/delete/' + id, {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: '_csrf=' + encodeURIComponent(csrfToken || '')
            })
              .then(function (r) {
                if (r.ok) {
                  window.location.reload();
                } else {
                  alert('删除失败');
                }
              })
              .catch(function () { alert('请求失败'); });
          };
          if (window.showConfirmModal) window.showConfirmModal(msg, doDelete);
          else if (confirm(msg)) doDelete();
        };
      });

      // 监听排序输入框变化，实时更新排序
      function initNewsSortInputs() {
        const inputs = document.querySelectorAll('.news-sort-input');
        inputs.forEach(function(input) {
          input.addEventListener('change', function() {
            const newsId = parseInt(input.getAttribute('data-id'), 10);
            const sortValue = parseInt(input.value, 10) || 0;
            
            // 显示加载状态
            const originalValue = input.value;
            input.disabled = true;
            
            // 发送请求更新排序
            fetch('/admin/news/update-sort', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrfToken
              },
              credentials: 'same-origin',
              body: JSON.stringify({ id: newsId, sort: sortValue })
            })
            .then(function(response) {
              if (!response.ok) {
                throw new Error('Network response was not ok');
              }
              return response.json();
            })
            .then(function(data) {
              if (data.success) {
                // 更新成功，刷新页面以重新排序
                window.location.reload();
              } else {
                // 更新失败，恢复原始值
                input.value = originalValue;
                alert('排序更新失败');
              }
            })
            .catch(function(error) {
              console.error('Error:', error);
              input.value = originalValue;
              alert('排序更新失败');
            })
            .finally(function() {
              input.disabled = false;
            });
          });
        });
      }

      // 初始化排序输入框
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initNewsSortInputs);
      } else {
        initNewsSortInputs();
      }
    })();
  </script>
</body>
</html>
