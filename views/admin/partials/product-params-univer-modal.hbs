{{!-- 产品参数 Excel 编辑弹窗，宽高 80%，内嵌 Univer 表格（需配合 CDN 与 init 脚本） --}}
<div class="product-params-univer-overlay" id="productParamsUniverOverlay" aria-hidden="true">
  <div class="product-params-univer-dialog" role="dialog" aria-modal="true" aria-labelledby="productParamsUniverTitle">
    <div class="product-params-univer-header">
      <h2 class="product-params-univer-title" id="productParamsUniverTitle">编辑 Excel 数据</h2>
      <button type="button" class="product-params-univer-close" id="productParamsUniverClose" aria-label="关闭"><iconify-icon icon="mdi:close"></iconify-icon></button>
    </div>
    <div class="product-params-univer-body">
      <div id="app" style="width:100%;height:100%;min-height:300px;"></div>
    </div>
    <div class="product-params-univer-footer">
      <button type="button" class="btn btn-secondary" id="productParamsUniverCancel">取消</button>
      <button type="button" class="btn btn-primary" id="productParamsUniverConfirm">确定</button>
    </div>
  </div>
</div>
