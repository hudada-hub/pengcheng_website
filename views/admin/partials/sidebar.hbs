<script>
  (function () {
    var KEY = 'pc_admin_nav_open_groups';
    var groups = document.querySelectorAll('.admin-nav-group[data-group]');
    if (!groups || !groups.length) return;

    var activeLink = document.querySelector('.admin-sidebar a.active');
    var activeGroup = activeLink ? activeLink.closest('.admin-nav-group[data-group]') : null;

    var saved = null;
    try { saved = JSON.parse(localStorage.getItem(KEY) || 'null'); } catch (e) { saved = null; }
    // 兼容旧数据（数组），但手风琴模式只保留一个
    var savedIds = Array.isArray(saved) ? saved : (saved ? [saved] : []);
    var savedId = savedIds && savedIds.length ? String(savedIds[0]) : '';

    groups.forEach(function (d) {
      var id = d.getAttribute('data-group') || '';
      if (savedId && id === savedId) d.open = true;
    });
    if (activeGroup) activeGroup.open = true;

    groups.forEach(function (d) {
      var summary = d.querySelector('summary');
      if (!summary) return;

      // 手风琴：只允许同时展开一个
      d.addEventListener('toggle', function () {
        if (d.open) {
          groups.forEach(function (x) {
            if (x !== d) x.open = false;
          });
        }
        var openId = '';
        groups.forEach(function (x) {
          if (x.open && !openId) openId = x.getAttribute('data-group') || '';
        });
        try { localStorage.setItem(KEY, JSON.stringify(openId ? [openId] : [])); } catch (e) {}
      });
    });

  })();
</script>

