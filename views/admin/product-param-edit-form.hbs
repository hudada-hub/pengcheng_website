<!DOCTYPE html>
<html><head><meta charset="UTF-8"></head><body><div id="admin-form-fragment">
  <div class="admin-card">
    <form class="admin-form" method="post" action="/admin/product-param-categories/save">
      <div class="admin-modal-form-scroll">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        {{#if param}}<input type="hidden" name="id" value="{{param.id}}">{{/if}}
        <div class="form-group">
          <label>标题（参数名称） <span style="color:var(--admin-danger);">*</span></label>
          <input type="text" name="title" id="ppTitle" required value="{{#if param}}{{param.title}}{{/if}}" placeholder="如：额定电压、容量等">
        </div>
        <div class="form-group">
          <label>语言 <span style="color:var(--admin-danger);">*</span></label>
          <select name="langId" required>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../defaultLangId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>排序（数字越小越靠前）</label>
          <input type="number" name="sort" value="{{#if param}}{{param.sort}}{{else}}0{{/if}}" min="0">
        </div>
        <div class="form-group">
          <label>状态</label>
          <select name="status">
            <option value="1" {{#if param}}{{#if (eq param.status 1)}}selected{{/if}}{{else}}selected{{/if}}>正常</option>
            <option value="0" {{#if param}}{{#if (eq param.status 0)}}selected{{/if}}{{/if}}>隐藏</option>
          </select>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">保存</button>
        <button type="button" class="btn admin-modal-form-cancel">取消</button>
      </div>
    </form>
  </div>
</div></body></html>
