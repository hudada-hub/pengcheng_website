<!DOCTYPE html>
<html><head><meta charset="UTF-8"></head><body><div id="admin-form-fragment">
  <div class="admin-card">
    <form class="admin-form" method="post" action="/admin/download-series/save" id="downloadSeriesEditForm">
      <div class="admin-modal-form-scroll">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="id" value="{{series.id}}">
        <div class="form-group">
          <label>系列名称 <span style="color:var(--admin-danger);">*</span></label>
          <input type="text" name="name" required value="{{series.name}}" placeholder="系列名称">
        </div>
        <div class="form-group">
          <label>语言 <span style="color:var(--admin-danger);">*</span></label>
          <select name="langId" required>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../series.langId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>排序</label>
          <input type="number" name="sort" value="{{series.sort}}" step="1">
        </div>
        <div class="form-group">
          <label>状态</label>
          <select name="status">
            <option value="1" {{#if (eq series.status 1)}}selected{{/if}}>正常</option>
            <option value="0" {{#if (eq series.status 0)}}selected{{/if}}>隐藏</option>
          </select>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">保存</button>
        <button type="button" class="btn admin-modal-form-cancel">取消</button>
      </div>
    </form>
  </div>
</div></body></html>
