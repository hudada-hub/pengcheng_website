<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 官网后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <link rel="stylesheet" href="/css/other/wangeditor.css">
  <script src="/js/iconify-icon.min.js"></script>
  <script src="/js/wangeditor.js"></script>
  <script src="/js/admin-file-manager.js"></script>
  <script src="/js/admin-richtext.js"></script>
  <script src="/js/admin-transfer.js"></script>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
        <div>
          <h1 style="margin:0;">{{title}}</h1>
          <div style="font-size:var(--font-size-sm);color:var(--admin-text-muted);margin:0.25rem 0;">排序数字越大，在列表中显示越靠前</div>
        </div>
        <div class="admin-page-toolbar__row">
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);">语言</label>
          <select id="industryCaseLangId" style="max-width:220px;">
            <option value="all" {{#if (eq selectedLangId '')}}selected{{/if}}>全部</option>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedLangId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);margin-left:1rem;">分类</label>
          <select id="industryCaseCategoryId" style="max-width:220px;">
            <option value="all" {{#if (eq selectedCategoryId '')}}selected{{/if}}>全部</option>
            {{#each categories}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedCategoryId)}}selected{{/if}}>{{this.title}}</option>
            {{/each}}
          </select>
          <button type="button" class="btn btn-primary" id="btnIndustryCaseAdd"><iconify-icon icon="mdi:plus"></iconify-icon> 新增</button>
          <button type="button" class="btn btn-secondary" id="btnIndustryCaseBatchDelete" style="margin-left:0.25rem;"><iconify-icon icon="mdi:delete-sweep"></iconify-icon> 批量删除</button>
          <button type="button" class="btn btn-primary" id="btnIndustryCaseBatchTranslate" style="margin-left:0.25rem;" disabled><iconify-icon icon="mdi:translate"></iconify-icon> 批量翻译</button>
        </div>
      </div>
      <form id="industryCaseBatchDeleteForm" method="post" action="/admin/industry-cases/batch-delete" style="display:none;">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
      </form>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:2.5rem;">
                <input type="checkbox" id="industryCaseSelectAll" title="全选" aria-label="全选">
              </th>
              <th>ID</th>
              <th>标题</th>
              <th id="industryCaseLangTh" style="{{#if (eq selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">语言</th>
              <th>分类</th>
              <th>置顶</th>
              <th>排序</th>
              <th>访问次数</th>
              <th>状态</th>
              <th style="width:220px;">操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each caseList}}
            <tr>
              <td><input type="checkbox" class="industry-case-row-cb" value="{{this.id}}" aria-label="选择"></td>
              <td>{{this.id}}</td>
              <td>{{this.title}}</td>
              <td class="industry-case-lang-cell" style="{{#if (eq ../selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">{{#if this.lang}}{{this.lang.name}} ({{this.lang.code}}){{else}}-{{/if}}</td>
              <td>{{#if this.categories}}{{join this.categories ", "}}{{else}}-{{/if}}</td>
              <td>{{#if (eq this.isTop 1)}}是{{else}}否{{/if}}</td>
              <td>
                <input type="number" class="industry-case-sort-input" data-id="{{this.id}}" value="{{this.sort}}" min="0" style="width:60px;">
              </td>
              <td>{{this.viewCount}}</td>
              <td>{{#if (eq this.status 1)}}<span class="status-normal">正常</span>{{else}}<span class="status-hidden">隐藏</span>{{/if}}</td>
              <td class="actions">
                <a href="#" class="btn-link industry-case-edit-link" data-id="{{this.id}}">编辑</a>
                <a href="#" class="industry-case-translate-link" data-id="{{this.id}}">一键翻译</a>
                <form method="post" action="/admin/industry-cases/delete/{{this.id}}" style="display:inline;">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <button type="submit" class="btn-link" data-popconfirm="确定删除该行业应用案例吗？">删除</button>
                </form>
              </td>
            </tr>
            {{else}}
            <tr><td colspan="10" style="text-align:center;color:var(--admin-text-muted);">暂无数据</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{#if pagination}}
      <div class="admin-pagination-wrap" style="margin-top:1rem;">
        {{> admin/pagination currentPage=pagination.currentPage totalPages=pagination.totalPages baseUrl=pagination.baseUrl}}
      </div>
      {{/if}}
    </main>
  </div>
  {{> admin/modal-form title="行业应用案例"}}
  {{> admin/file-manager-modal}}
  {{> admin/translate-modal idPrefix="industryCaseTranslate"}}
  {{!-- 批量翻译弹窗：勾选目标语言后提交 --}}
  <div id="industryCaseBatchTranslateModalOverlay" class="admin-modal-overlay admin-translate-modal-overlay" aria-hidden="true">
    <div class="admin-modal-dialog admin-translate-modal" role="dialog" aria-modal="true" aria-labelledby="industryCaseBatchTranslateModalTitle">
      <div class="admin-translate-modal-header">
        <h2 class="admin-translate-modal-title" id="industryCaseBatchTranslateModalTitle">批量翻译</h2>
        <button type="button" class="admin-translate-modal-close" id="industryCaseBatchTranslateModalClose" aria-label="关闭">
          <iconify-icon icon="mdi:close"></iconify-icon>
        </button>
      </div>
      <div class="admin-translate-modal-body" id="industryCaseBatchTranslateModalBody">
        <p style="margin-bottom:0.5rem;">选择要翻译成的语言（可多选）：</p>
        <div style="max-height:200px;overflow:auto;">
          {{#each langs}}
          <label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="industry-case-batch-translate-lang-cb" value="{{this.id}}"> {{this.name}} ({{this.code}})</label>
          {{/each}}
        </div>
      </div>
      <div class="admin-translate-modal-footer">
        <div class="admin-translate-modal-actions">
          <button type="button" class="btn btn-secondary" id="industryCaseBatchTranslateModalCancel">取消</button>
          <button type="button" class="btn btn-primary" id="industryCaseBatchTranslateModalSubmit">开始翻译</button>
        </div>
      </div>
    </div>
  </div>
  {{> admin/confirm-modal}}
  <script>
    (function () {
      var csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : '';
      var formOverlay = document.getElementById('adminModalFormOverlay');
      var formModalBody = document.querySelector('.admin-modal-form-body');
      var formModalTitle = document.getElementById('adminModalFormTitle');
      var rte = null;

      function closeFormModal() {
        if (rte && typeof rte.destroy === 'function') rte.destroy();
        rte = null;
        if (formOverlay) { formOverlay.classList.remove('open'); formOverlay.setAttribute('aria-hidden', 'true'); }
      }

      function bindMetaSync(container) {
        var titleEl = container.querySelector('#industryCaseTitle');
        var metaEl = container.querySelector('#industryCaseMetaTitle');
        if (!titleEl || !metaEl) return;
        if (!metaEl.value && titleEl.value) metaEl.value = titleEl.value;
        titleEl.addEventListener('input', function () { if (!metaEl.dataset.edited) metaEl.value = titleEl.value; });
        metaEl.addEventListener('input', function () { metaEl.dataset.edited = '1'; });
      }

      function bindFilePickers(container) {
        if (!container || !window.AdminFileManager || !window.AdminFileManager.open) return;
        var thumbInput = container.querySelector('#industryCaseThumbnail');
        var bannerInput = container.querySelector('#industryCaseBannerUrl');
        var thumbPreview = container.querySelector('#industryCaseThumbnailPreview');
        var bannerPreview = container.querySelector('#industryCaseBannerPreview');
        var btnThumb = container.querySelector('#industryCaseBtnPickThumbnail');
        var btnBanner = container.querySelector('#industryCaseBtnPickBanner');
        if (btnThumb && thumbInput) btnThumb.onclick = function () { window.AdminFileManager.open({ type: 'image', targetInput: thumbInput, targetPreview: thumbPreview }); };
        if (btnBanner && bannerInput) btnBanner.onclick = function () { window.AdminFileManager.open({ type: 'image', targetInput: bannerInput, targetPreview: bannerPreview }); };
      }

      function initEditor(container) {
        if (!container || !window.AdminRichText || !window.AdminRichText.init) return;
        rte = window.AdminRichText.init({
          root: container,
          editorSelector: '#industry-case-editor-container',
          toolbarSelector: '#industry-case-toolbar-container',
          textareaSelector: '#industryCaseContentTa',
          placeholder: '请输入正文...',
        });
      }

      function openFormModal(titleText, formUrl) {
        if (rte && typeof rte.destroy === 'function') rte.destroy();
        rte = null;
        if (!formOverlay || !formModalBody) return;
        formModalTitle.textContent = titleText;
        formModalBody.innerHTML = '<p style="text-align:center;color:var(--admin-text-muted);">加载中...</p>';
        formOverlay.classList.add('open');
        formOverlay.setAttribute('aria-hidden', 'false');
        fetch(formUrl, { credentials: 'same-origin' })
          .then(function (r) { return r.text(); })
          .then(function (html) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');
            var frag = doc.getElementById('admin-form-fragment');
            formModalBody.innerHTML = frag ? frag.innerHTML : html;
            var _form = formModalBody.querySelector('form');
            if (_form) { var _inp = document.createElement('input'); _inp.type = 'hidden'; _inp.name = 'returnUrl'; _inp.value = window.location.href; _form.appendChild(_inp); }
            var cancelBtn = formModalBody.querySelector('.admin-modal-form-cancel');
            if (cancelBtn) cancelBtn.onclick = closeFormModal;
            var form = formModalBody.querySelector('#industryCaseEditForm');
            if (form) {
              form.onsubmit = function () {
                if (rte && rte.sync) rte.sync();
              };
            }
            initEditor(formModalBody);
            bindMetaSync(formModalBody);
            bindFilePickers(formModalBody);
            if (window.AdminTransfer && window.AdminTransfer.initAll) window.AdminTransfer.initAll();
          })
          .catch(function () { formModalBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }

      var closeBtn = document.getElementById('adminModalFormClose');
      if (closeBtn) closeBtn.onclick = closeFormModal;
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && formOverlay && formOverlay.classList.contains('open')) closeFormModal(); });
      var addBtn = document.getElementById('btnIndustryCaseAdd');
      if (addBtn) addBtn.onclick = function () { openFormModal('新增行业应用案例', '/admin/industry-cases/edit?modal=1'); };
      document.querySelectorAll('.industry-case-edit-link').forEach(function (a) {
        a.onclick = function (e) { e.preventDefault(); var id = a.getAttribute('data-id'); if (id) openFormModal('编辑行业应用案例', '/admin/industry-cases/edit/' + id + '?modal=1'); };
      });
      var langSelect = document.getElementById('industryCaseLangId');
      var categorySelect = document.getElementById('industryCaseCategoryId');
      
      function updateFilter() {
        var langVal = (langSelect.value || '').trim();
        var categoryVal = (categorySelect.value || '').trim();
        var url = '/admin/industry-cases';
        var params = [];
        
        if (langVal && langVal !== 'all') params.push('langId=' + encodeURIComponent(langVal));
        else if (langVal === 'all') params.push('langId=all');
        
        if (categoryVal && categoryVal !== 'all') params.push('categoryId=' + encodeURIComponent(categoryVal));
        else if (categoryVal === 'all') params.push('categoryId=all');
        
        if (params.length > 0) url += '?' + params.join('&');
        window.location.href = url;
      }
      
      if (langSelect) {
        langSelect.onchange = updateFilter;
      }
      
      if (categorySelect) {
        categorySelect.onchange = updateFilter;
      }
      var selectAll = document.getElementById('industryCaseSelectAll');
      if (selectAll) {
        selectAll.onclick = function () {
          var cbs = document.querySelectorAll('.industry-case-row-cb');
          cbs.forEach(function (cb) { cb.checked = selectAll.checked; });
        };
      }
      // 批量翻译：勾选控制
      var btnBatchTranslate = document.getElementById('btnIndustryCaseBatchTranslate');
      var rowCbs = document.querySelectorAll('.industry-case-row-cb');
      function syncBatchTranslateBtn() {
        var checked = document.querySelectorAll('.industry-case-row-cb:checked');
        if (btnBatchTranslate) btnBatchTranslate.disabled = checked.length === 0;
      }
      rowCbs.forEach(function (cb) { cb.addEventListener('change', syncBatchTranslateBtn); });
      if (selectAll) selectAll.addEventListener('change', syncBatchTranslateBtn);
      syncBatchTranslateBtn();
      // 批量翻译弹窗
      var batchTranslateOverlay = document.getElementById('industryCaseBatchTranslateModalOverlay');
      function openBatchTranslateModal() {
        var ids = Array.prototype.slice.call(document.querySelectorAll('.industry-case-row-cb:checked')).map(function (cb) { return parseInt(cb.value, 10); }).filter(function (n) { return !isNaN(n); });
        if (!ids.length) { alert('请先勾选要翻译的行业应用案例'); return; }
        if (!batchTranslateOverlay) return;
        batchTranslateOverlay.classList.add('open');
        batchTranslateOverlay.setAttribute('aria-hidden', 'false');
        batchTranslateOverlay.dataset.sourceIds = ids.join(',');
      }
      function closeBatchTranslateModal() {
        if (batchTranslateOverlay) { batchTranslateOverlay.classList.remove('open'); batchTranslateOverlay.setAttribute('aria-hidden', 'true'); }
      }
      if (btnBatchTranslate) btnBatchTranslate.onclick = openBatchTranslateModal;
      document.getElementById('industryCaseBatchTranslateModalClose').onclick = closeBatchTranslateModal;
      document.getElementById('industryCaseBatchTranslateModalCancel').onclick = closeBatchTranslateModal;
      if (batchTranslateOverlay) batchTranslateOverlay.onclick = function (e) { if (e.target === batchTranslateOverlay) closeBatchTranslateModal(); };
      document.getElementById('industryCaseBatchTranslateModalSubmit').onclick = function () {
        var langCbs = document.querySelectorAll('.industry-case-batch-translate-lang-cb:checked');
        var targetLangIds = [];
        langCbs.forEach(function (cb) { targetLangIds.push(parseInt(cb.value, 10)); });
        if (!targetLangIds.length) { alert('请至少选择一种目标语言'); return; }
        var sourceIdsStr = batchTranslateOverlay && batchTranslateOverlay.dataset.sourceIds ? batchTranslateOverlay.dataset.sourceIds : '';
        var sourceIds = sourceIdsStr.split(',').map(function (s) { return parseInt(s.trim(), 10); }).filter(function (n) { return !isNaN(n) && n > 0; });
        if (!sourceIds.length) { alert('未找到要翻译的行业应用案例'); return; }
        var btn = document.getElementById('industryCaseBatchTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/industry-case/translate-batch', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken },
          body: JSON.stringify({ _csrf: csrfToken, sourceIds: sourceIds, targetLangIds: targetLangIds })
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeBatchTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };
      var batchDeleteBtn = document.getElementById('btnIndustryCaseBatchDelete');
      var batchDeleteForm = document.getElementById('industryCaseBatchDeleteForm');
      if (batchDeleteBtn && batchDeleteForm) {
        batchDeleteBtn.onclick = function () {
          var checked = document.querySelectorAll('.industry-case-row-cb:checked');
          var ids = [];
          checked.forEach(function (cb) { ids.push(cb.value); });
          if (!ids.length) { alert('请先勾选要删除的案例'); return; }
          var msg = '确定删除所选 ' + ids.length + ' 条行业应用案例吗？';
          var doSubmit = function () {
            batchDeleteForm.innerHTML = '<input type="hidden" name="_csrf" value="' + (csrfToken || '') + '">';
            ids.forEach(function (id) {
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'ids';
              input.value = id;
              batchDeleteForm.appendChild(input);
            });
            batchDeleteForm.submit();
          };
          if (window.showConfirmModal) {
            window.showConfirmModal(msg, doSubmit);
          } else if (confirm(msg)) {
            doSubmit();
          }
        };
      }
      var translateOverlay = document.getElementById('industryCaseTranslateModalOverlay');
      var translateBody = document.getElementById('industryCaseTranslateModalBody');
      var translateSourceId = 0;
      function escapeHtml(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;').replace(/'/g, '&#039;'); }
      function loadTranslateLangs() {
        if (!translateBody || !translateSourceId) return;
        var retranslateEl = document.getElementById('industryCaseTranslateRetranslateCb');
        var retranslate = retranslateEl ? retranslateEl.checked : false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        var url = '/admin/api/industry-case/missing-langs?id=' + encodeURIComponent(translateSourceId);
        if (retranslate) url += '&retranslate=1';
        fetch(url, { credentials: 'same-origin' }).then(function (r) { return r.json(); })
          .then(function (langs) {
            if (!langs || !langs.length) { translateBody.innerHTML = '<p class="admin-text-muted">' + (retranslate ? '暂无其他语言。' : '暂无缺失语言。') + '</p>'; return; }
            var html = '<p style="margin-bottom:0.5rem;">选择要翻译成的语言：</p><button type="button" class="btn btn-secondary btn-sm" id="industryCaseTranslateSelectAll">一键补充缺失的所有语言</button><div style="margin-top:0.75rem;max-height:200px;overflow:auto;">';
            langs.forEach(function (l) { html += '<label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="industry-case-translate-cb" value="' + escapeHtml(String(l.id)) + '"> ' + escapeHtml(l.name) + ' (' + escapeHtml(l.code) + ')</label>'; });
            html += '</div>';
            translateBody.innerHTML = html;
            var selAll = document.getElementById('industryCaseTranslateSelectAll');
            if (selAll) selAll.onclick = function () { translateBody.querySelectorAll('.industry-case-translate-cb').forEach(function (cb) { cb.checked = true; }); };
          }).catch(function () { translateBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }
      function openTranslateModal(id) {
        translateSourceId = id;
        if (!translateOverlay || !translateBody) return;
        var cb = document.getElementById('industryCaseTranslateRetranslateCb');
        if (cb) cb.checked = false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        translateOverlay.classList.add('open');
        translateOverlay.setAttribute('aria-hidden', 'false');
        loadTranslateLangs();
      }
      function closeTranslateModal() { if (translateOverlay) { translateOverlay.classList.remove('open'); translateOverlay.setAttribute('aria-hidden', 'true'); } }
      document.getElementById('industryCaseTranslateModalClose').onclick = closeTranslateModal;
      document.getElementById('industryCaseTranslateModalCancel').onclick = closeTranslateModal;
      if (translateOverlay) translateOverlay.onclick = function (e) { if (e.target === translateOverlay) closeTranslateModal(); };
      var retranslateCb = document.getElementById('industryCaseTranslateRetranslateCb');
      if (retranslateCb) retranslateCb.onchange = loadTranslateLangs;
      document.querySelectorAll('.industry-case-translate-link').forEach(function (a) {
        a.onclick = function (e) { e.preventDefault(); var id = a.getAttribute('data-id'); if (id) openTranslateModal(parseInt(id, 10)); };
      });
      document.getElementById('industryCaseTranslateModalSubmit').onclick = function () {
        var cbs = document.querySelectorAll('#industryCaseTranslateModalBody .industry-case-translate-cb:checked');
        var ids = [];
        cbs.forEach(function (cb) { ids.push(parseInt(cb.value, 10)); });
        if (!ids.length) { alert('请至少选择一种语言'); return; }
        var btn = document.getElementById('industryCaseTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/industry-case/translate', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken }, body: JSON.stringify({ _csrf: csrfToken, sourceId: translateSourceId, targetLangIds: ids }) })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };
      var paginationNav = document.querySelector('.admin-pagination');
      if (paginationNav) {
        var baseUrl = paginationNav.getAttribute('data-base-url');
        var cur = parseInt(paginationNav.getAttribute('data-current'), 10) || 1;
        var total = parseInt(paginationNav.getAttribute('data-total'), 10) || 1;
        var pageSize = parseInt(paginationNav.getAttribute('data-page-size'), 10) || 15;
        var prevBtn = paginationNav.querySelector('.admin-pagination-prev');
        var nextBtn = paginationNav.querySelector('.admin-pagination-next');
        
        // 上一页/下一页
        if (prevBtn && baseUrl) prevBtn.onclick = function () { if (cur > 1) window.location.href = baseUrl + '&page=' + (cur - 1); };
        if (nextBtn && baseUrl) nextBtn.onclick = function () { if (cur < total) window.location.href = baseUrl + '&page=' + (cur + 1); };
        
        // 数字分页按钮
        paginationNav.querySelectorAll('.admin-pagination-number').forEach(function (btn) {
          btn.onclick = function () {
            var page = parseInt(btn.getAttribute('data-page'), 10);
            if (page && page !== cur) {
              window.location.href = baseUrl + '&page=' + page;
            }
          };
        });
        
        // 每页大小调整
        var pageSizeSelect = paginationNav.querySelector('.admin-pagination-pagesize-select');
        if (pageSizeSelect) {
          pageSizeSelect.onchange = function () {
            var newPageSize = parseInt(pageSizeSelect.value, 10);
            if (newPageSize && newPageSize !== pageSize) {
              // 构建新的 URL，移除原 pageSize 参数
              var url = '/admin/industry-cases';
              var params = [];
              
              // 从 baseUrl 中提取参数
              var baseUrlParts = baseUrl.split('?')[1];
              if (baseUrlParts) {
                var paramPairs = baseUrlParts.split('&');
                for (var i = 0; i < paramPairs.length; i++) {
                  var pair = paramPairs[i].split('=');
                  var key = decodeURIComponent(pair[0]);
                  var value = decodeURIComponent(pair[1] || '');
                  // 跳过 pageSize 和 page 参数
                  if (key !== 'pageSize' && key !== 'page') {
                    params.push(key + '=' + value);
                  }
                }
              }
              
              // 添加新的 page=1 和新的 pageSize
              params.push('page=1');
              params.push('pageSize=' + newPageSize);
              
              window.location.href = url + '?' + params.join('&');
            }
          };
        }
        
        // 跳转页码
        var jumpInput = paginationNav.querySelector('.admin-pagination-jump-input');
        var jumpBtn = paginationNav.querySelector('.admin-pagination-jump-btn');
        if (jumpInput && jumpBtn) {
          jumpBtn.onclick = function () {
            var page = parseInt(jumpInput.value, 10);
            if (page && page >= 1 && page <= total && page !== cur) {
              window.location.href = baseUrl + '&page=' + page;
            }
          };
          jumpInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
              var page = parseInt(jumpInput.value, 10);
              if (page && page >= 1 && page <= total && page !== cur) {
                window.location.href = baseUrl + '&page=' + page;
              }
            }
          });
        }
      }

      // 监听排序输入框变化，实时更新排序
      function initIndustryCaseSortInputs() {
        const inputs = document.querySelectorAll('.industry-case-sort-input');
        inputs.forEach(function(input) {
          input.addEventListener('change', function() {
            const industryCaseId = parseInt(input.getAttribute('data-id'), 10);
            const sortValue = parseInt(input.value, 10) || 0;
            
            // 显示加载状态
            const originalValue = input.value;
            input.disabled = true;
            
            // 发送请求更新排序
            fetch('/admin/industry-cases/update-sort', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrfToken
              },
              credentials: 'same-origin',
              body: JSON.stringify({ id: industryCaseId, sort: sortValue })
            })
            .then(function(response) {
              if (!response.ok) {
                throw new Error('Network response was not ok');
              }
              return response.json();
            })
            .then(function(data) {
              if (data.success) {
                // 更新成功，刷新页面以重新排序
                window.location.reload();
              } else {
                // 更新失败，恢复原始值
                input.value = originalValue;
                alert('排序更新失败');
              }
            })
            .catch(function(error) {
              console.error('Error:', error);
              input.value = originalValue;
              alert('排序更新失败');
            })
            .finally(function() {
              input.disabled = false;
            });
          });
        });
      }

      // 初始化排序输入框
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initIndustryCaseSortInputs);
      } else {
        initIndustryCaseSortInputs();
      }
    })();
  </script>
</body>
</html>
