<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 鹏成后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <script src="/js/iconify-icon.min.js"></script>
  <style>
    .admin-table-wrap { overflow-x: auto; }
    .admin-table { min-width: 1400px; }
    .admin-table th,
    .admin-table td {
      white-space: nowrap;
      padding: 12px 16px;
    }
    .admin-table td.message-cell {
      white-space: normal;
      max-width: 300px;
      min-width: 200px;
    }
    .admin-table td.files-cell {
      min-width: 150px;
    }
    .file-link {
      display: block;
      font-size: var(--font-size-sm);
      color: var(--admin-primary);
      text-decoration: none;
      margin-bottom: 4px;
    }
    .file-link:hover {
      text-decoration: underline;
    }
    .text-muted {
      color: var(--admin-text-muted);
    }
    .status-badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
    }
    .status-normal {
      background: #e6f7e6;
      color: #52c41a;
    }
    .status-deleted {
      background: #fff1f0;
      color: #ff4d4f;
    }
    /* Image preview styles */
    .file-item {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }
    .file-thumb {
      width: 40px;
      height: 40px;
      border-radius: 4px;
      object-fit: cover;
      cursor: pointer;
      border: 1px solid #e0e0e0;
    }
    .file-thumb:hover {
      opacity: 0.8;
    }
    .file-info {
      flex: 1;
      min-width: 0;
    }
    .file-name {
      font-size: 12px;
      color: var(--admin-text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    /* Lightbox styles */
    .lightbox {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.85);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
    }
    .lightbox.active {
      display: flex;
    }
    .lightbox img {
      max-width: 90%;
      max-height: 90%;
      object-fit: contain;
      border-radius: 4px;
    }
    .lightbox-close {
      position: absolute;
      top: 20px;
      right: 20px;
      color: #fff;
      font-size: 32px;
      cursor: pointer;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.1);
      border-radius: 50%;
    }
    .lightbox-close:hover {
      background: rgba(255,255,255,0.2);
    }
  </style>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
        <h1 style="margin:0;">{{title}}</h1>
        <p style="margin:0;font-size:var(--font-size-sm);color:var(--admin-text-muted);">前台用户提交的海外招募表单，仅查看与删除</p>
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>公司名称</th>
              <th>城市</th>
              <th>国家</th>
              <th>邮箱</th>
              <th>电话</th>
              <th>留言</th>
              <th>语言</th>
              <th>资质文件</th>
              <th>状态</th>
              <th>提交时间</th>
              <th>更新时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each list}}
            <tr>
              <td>{{this.id}}</td>
              <td>{{this.companyName}}</td>
              <td>{{#if this.city}}{{this.city}}{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td>{{#if this.country}}{{this.country}}{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td>{{#if this.email}}<a href="mailto:{{this.email}}">{{this.email}}</a>{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td>{{#if this.phone}}<a href="tel:{{this.phone}}">{{this.phone}}</a>{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td class="message-cell">{{#if this.message}}{{this.message}}{{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td>{{#if this.lang}}{{this.lang.name}} ({{this.lang.code}}){{else}}<span class="text-muted">-</span>{{/if}}</td>
              <td class="files-cell" id="files-cell-{{this.id}}">
                {{#if this.qualificationFiles}}
                  {{#each this.qualificationFiles}}
                    <div class="file-item" data-filename="{{this.fileName}}" data-fileurl="{{this.fileUrl}}">
                      <div class="file-thumb-wrapper" data-filename="{{this.fileName}}" data-fileurl="{{this.fileUrl}}">
                        <!-- Will be replaced by JavaScript for images -->
                        <div class="file-icon-placeholder" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:#f5f5f5;border-radius:4px;border:1px solid #e0e0e0;">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                          </svg>
                        </div>
                      </div>
                      <div class="file-info">
                        <div class="file-name" title="{{this.fileName}}">{{this.fileName}}</div>
                        <a href="{{this.fileUrl}}" target="_blank" rel="noopener" class="file-link" download title="点击下载">下载</a>
                      </div>
                    </div>
                  {{/each}}
                {{else}}
                  <span class="text-muted">-</span>
                {{/if}}
              </td>
              <td>
                {{#if (eq this.status 1)}}
                  <span class="status-badge status-normal">正常</span>
                {{else}}
                  <span class="status-badge status-deleted">已删除</span>
                {{/if}}
              </td>
              <td>{{this.createdAtFormatted}}</td>
              <td>{{this.updatedAtFormatted}}</td>
              <td class="actions">
                <form method="post" action="/admin/overseas-recruit/delete/{{this.id}}" style="display:inline;">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <button type="submit" class="btn-link" data-popconfirm="确定删除该条记录吗？">删除</button>
                </form>
              </td>
            </tr>
            {{else}}
            <tr><td colspan="13" style="text-align:center;color:var(--admin-text-muted);">暂无数据</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{#if pagination}}
      <div class="admin-pagination-wrap" style="margin-top:1rem;">
        {{> admin/pagination currentPage=pagination.currentPage totalPages=pagination.totalPages baseUrl=pagination.baseUrl}}
      </div>
      <script>
        (function () {
          var paginationNav = document.querySelector('.admin-pagination');
          if (!paginationNav) return;
          var baseUrl = paginationNav.getAttribute('data-base-url');
          var cur = parseInt(paginationNav.getAttribute('data-current'), 10) || 1;
          var total = parseInt(paginationNav.getAttribute('data-total'), 10) || 1;
          var prevBtn = paginationNav.querySelector('.admin-pagination-prev');
          var nextBtn = paginationNav.querySelector('.admin-pagination-next');
          if (prevBtn && baseUrl) prevBtn.onclick = function () { if (cur > 1) window.location.href = baseUrl + '&page=' + (cur - 1); };
          if (nextBtn && baseUrl) nextBtn.onclick = function () { if (cur < total) window.location.href = baseUrl + '&page=' + (cur + 1); };
        })();
      </script>
      {{/if}}
    </main>
  </div>
  {{> admin/confirm-modal}}

  <!-- Lightbox for image preview -->
  <div id="lightbox" class="lightbox" onclick="closeLightbox()">
    <div class="lightbox-close">&times;</div>
    <img id="lightbox-img" src="" alt="Preview">
  </div>

  <script>
    // Helper function to check if file is an image
    function isImageFile(filename) {
      if (!filename) return false;
      const ext = filename.split('.').pop().toLowerCase();
      return ['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp', 'svg'].includes(ext);
    }

    // Open lightbox
    function openLightbox(src) {
      const lightbox = document.getElementById('lightbox');
      const img = document.getElementById('lightbox-img');
      img.src = src;
      lightbox.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    // Close lightbox
    function closeLightbox() {
      const lightbox = document.getElementById('lightbox');
      lightbox.classList.remove('active');
      document.body.style.overflow = '';
    }

    // Close on escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeLightbox();
      }
    });

    // Process file items on page load
    document.addEventListener('DOMContentLoaded', function() {
      const fileThumbWrappers = document.querySelectorAll('.file-thumb-wrapper');
      fileThumbWrappers.forEach(function(wrapper) {
        const filename = wrapper.getAttribute('data-filename');
        const fileurl = wrapper.getAttribute('data-fileurl');
        
        if (isImageFile(filename)) {
          // Replace placeholder with image
          wrapper.innerHTML = '<img src="' + fileurl + '" alt="' + filename + '" class="file-thumb" onclick="openLightbox(\'' + fileurl + '\')">';
        }
      });
    });
  </script>
</body>
</html>
