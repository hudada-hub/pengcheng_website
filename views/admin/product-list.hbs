        batchDeleteBtn.onclick = function () {
          var checked = document.querySelectorAll('.product-row-cb:checked');
          var ids = []; checked.forEach(function (cb) { ids.push(cb.value); });
          if (!ids.length) { alert('请先勾选要删除的产品'); return; }
          var msg = '确定删除所选 ' + ids.length + ' 个产品吗？';
          var doSubmit = function () {
            batchDeleteForm.innerHTML = '<input type="hidden" name="_csrf" value="' + (csrfToken || '') + '">';
            ids.forEach(function (id) {
              var input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'ids';
              input.value = id;
              batchDeleteForm.appendChild(input);
            });
            batchDeleteForm.submit();
          };
          if (window.showConfirmModal) {
            window.showConfirmModal(msg, doSubmit);
          } else if (confirm(msg)) {
            doSubmit();
          }
        };
      }
      // 批量翻译弹窗
      var batchTranslateOverlay = document.getElementById('productBatchTranslateModalOverlay');
      function openBatchTranslateModal() {
        var ids = Array.prototype.slice.call(document.querySelectorAll('.product-row-cb:checked')).map(function (cb) { return parseInt(cb.value, 10); }).filter(function (n) { return !isNaN(n); });
        if (!ids.length) { alert('请先勾选要翻译的产品'); return; }
        if (!batchTranslateOverlay) return;
        batchTranslateOverlay.classList.add('open');
        batchTranslateOverlay.setAttribute('aria-hidden', 'false');
        batchTranslateOverlay.dataset.sourceIds = ids.join(',');
      }
      function closeBatchTranslateModal() {
        if (batchTranslateOverlay) { batchTranslateOverlay.classList.remove('open'); batchTranslateOverlay.setAttribute('aria-hidden', 'true'); }
      }
      if (btnBatchTranslate) btnBatchTranslate.onclick = openBatchTranslateModal;
      document.getElementById('productBatchTranslateModalClose').onclick = closeBatchTranslateModal;
      document.getElementById('productBatchTranslateModalCancel').onclick = closeBatchTranslateModal;
      if (batchTranslateOverlay) batchTranslateOverlay.onclick = function (e) { if (e.target === batchTranslateOverlay) closeBatchTranslateModal(); };
      document.getElementById('productBatchTranslateModalSubmit').onclick = function () {
        var langCbs = document.querySelectorAll('.product-batch-translate-lang-cb:checked');
        var targetLangIds = [];
        langCbs.forEach(function (cb) { targetLangIds.push(parseInt(cb.value, 10)); });
        if (!targetLangIds.length) { alert('请至少选择一种目标语言'); return; }
        var sourceIdsStr = batchTranslateOverlay && batchTranslateOverlay.dataset.sourceIds ? batchTranslateOverlay.dataset.sourceIds : '';
        var sourceIds = sourceIdsStr.split(',').map(function (s) { return parseInt(s.trim(), 10); }).filter(function (n) { return !isNaN(n) && n > 0; });
        if (!sourceIds.length) { alert('未找到要翻译的产品'); return; }
        var btn = document.getElementById('productBatchTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/product/translate-batch', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken },
          body: JSON.stringify({ _csrf: csrfToken, sourceIds: sourceIds, targetLangIds: targetLangIds })
        })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeBatchTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };
      var translateOverlay = document.getElementById('productTranslateModalOverlay');
      var translateBody = document.getElementById('productTranslateModalBody');
      var translateSourceId = 0;
      function escapeHtml(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\"/g, '&quot;').replace(/'/g, '&#039;'); }
      function loadTranslateLangs() {
        if (!translateBody || !translateSourceId) return;
        var retranslateEl = document.getElementById('productTranslateRetranslateCb');
        var retranslate = retranslateEl ? retranslateEl.checked : false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        var url = '/admin/api/product/missing-langs?id=' + encodeURIComponent(translateSourceId);
        if (retranslate) url += '&retranslate=1';
        fetch(url, { credentials: 'same-origin' }).then(function (r) { return r.json(); })
          .then(function (langs) {
            if (!langs || !langs.length) { translateBody.innerHTML = '<p class="admin-text-muted">' + (retranslate ? '暂无其他语言。' : '暂无缺失语言。') + '</p>'; return; }
            var html = '<p style="margin-bottom:0.5rem;">选择要翻译成的语言：</p><button type="button" class="btn btn-secondary btn-sm" id="productTranslateSelectAll">一键补充缺失的所有语言</button><div style="margin-top:0.75rem;max-height:200px;overflow:auto;">';
            langs.forEach(function (l) { html += '<label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="product-translate-cb" value="' + escapeHtml(String(l.id)) + '"> ' + escapeHtml(l.name) + ' (' + escapeHtml(l.code) + ')</label>'; });
            html += '</div>';
            translateBody.innerHTML = html;
            var selAll = document.getElementById('productTranslateSelectAll');
            if (selAll) selAll.onclick = function () { translateBody.querySelectorAll('.product-translate-cb').forEach(function (cb) { cb.checked = true; }); };
          }).catch(function () { translateBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }
      function openTranslateModal(id) {
        translateSourceId = id;
        if (!translateOverlay || !translateBody) return;
        var cb = document.getElementById('productTranslateRetranslateCb');
        if (cb) cb.checked = false;
        translateBody.innerHTML = '<p class="admin-text-muted">加载中...</p>';
        translateOverlay.classList.add('open');
        translateOverlay.setAttribute('aria-hidden', 'false');
        loadTranslateLangs();
      }
      function closeTranslateModal() { if (translateOverlay) { translateOverlay.classList.remove('open'); translateOverlay.setAttribute('aria-hidden', 'true'); } }
      document.getElementById('productTranslateModalClose').onclick = closeTranslateModal;
      document.getElementById('productTranslateModalCancel').onclick = closeTranslateModal;
      if (translateOverlay) translateOverlay.onclick = function (e) { if (e.target === translateOverlay) closeTranslateModal(); };
      var retranslateCb = document.getElementById('productTranslateRetranslateCb');
      if (retranslateCb) retranslateCb.onchange = loadTranslateLangs;
      document.querySelectorAll('.product-translate-link').forEach(function (a) {
        a.onclick = function (e) { e.preventDefault(); var id = a.getAttribute('data-id'); if (id) openTranslateModal(parseInt(id, 10)); };
      });
      document.getElementById('productTranslateModalSubmit').onclick = function () {
        var cbs = document.querySelectorAll('#productTranslateModalBody .product-translate-cb:checked');
        var ids = [];
        cbs.forEach(function (cb) { ids.push(parseInt(cb.value, 10)); });
        if (!ids.length) { alert('请至少选择一种语言'); return; }
        var btn = document.getElementById('productTranslateModalSubmit');
        var oldText = btn.textContent;
        btn.disabled = true;
        btn.textContent = '翻译中...';
        fetch('/admin/api/product/translate', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json', 'csrf-token': csrfToken }, body: JSON.stringify({ _csrf: csrfToken, sourceId: translateSourceId, targetLangIds: ids }) })
          .then(function (r) { return r.json(); })
          .then(function (d) {
            btn.disabled = false;
            btn.textContent = oldText;
            if (d && d.ok) { alert(d.message || '翻译完成'); closeTranslateModal(); window.location.reload(); }
            else { alert(d && d.message ? d.message : '翻译失败'); }
          })
          .catch(function () { btn.disabled = false; btn.textContent = oldText; alert('请求失败'); });
      };

      // 单个删除功能（AJAX）
      document.querySelectorAll('.product-delete-btn').forEach(function (btn) {
        btn.onclick = function () {
          var id = btn.getAttribute('data-id');
          var msg = btn.getAttribute('data-popconfirm') || '确定删除吗？';
          var doDelete = function () {
            fetch('/admin/products/delete/' + id, {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: '_csrf=' + encodeURIComponent(csrfToken || '')
            })
              .then(function (r) {
                if (r.ok) {
                  window.location.reload();
                } else {
                  alert('删除失败');
                }
              })
              .catch(function () { alert('请求失败'); });
          };
          if (window.showConfirmModal) window.showConfirmModal(msg, doDelete);
          else if (confirm(msg)) doDelete();
        };
      });

      // 监听排序输入框变化，实时更新排序
      function initProductSortInputs() {
        const inputs = document.querySelectorAll('.product-sort-input');
        inputs.forEach(function(input) {
          input.addEventListener('change', function() {
            const productId = parseInt(input.getAttribute('data-id'), 10);
            const sortValue = parseInt(input.value, 10) || 0;
            
            // 显示加载状态
            const originalValue = input.value;
            input.disabled = true;
            
            // 发送请求更新排序
            fetch('/admin/products/update-sort', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
              },
              credentials: 'same-origin',
              body: JSON.stringify({ id: productId, sort: sortValue })
            })
            .then(function(response) {
              if (!response.ok) {
                throw new Error('Network response was not ok');
              }
              return response.json();
            })
            .then(function(data) {
              if (data.success) {
                // 更新成功，刷新页面以重新排序
                window.location.reload();
              } else {
                // 更新失败，恢复原始值
                input.value = originalValue;
                alert('排序更新失败');
              }
            })
            .catch(function(error) {
              console.error('Error:', error);
              input.value = originalValue;
              alert('排序更新失败');
            })
            .finally(function() {
              input.disabled = false;
            });
          });
        });
      }

      // 初始化排序输入框
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initProductSortInputs);
      } else {
        initProductSortInputs();
      }
    })();
  </script>
</body>
</html>
