            var jumpPage = parseInt(jumpInput.value, 10);
            if (jumpPage && jumpPage >= 1 && jumpPage <= total && jumpPage !== cur) {
              window.location.href = baseUrl + '&page=' + jumpPage;
            } else if (jumpPage && jumpPage > total) {
              alert('页码不能超过总页数 ' + total);
            } else if (jumpPage && jumpPage < 1) {
              alert('页码必须大于 0');
