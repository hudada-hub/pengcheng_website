<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 鹏成后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <script src="/js/iconify-icon.min.js"></script>
  <script src="/js/admin-file-manager.js"></script>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
           <div>
          <h1 style="margin:0;">{{title}}</h1>
          <div style="font-size:var(--font-size-sm);color:var(--admin-text-muted);margin:0.25rem 0;">排序数字越大，在列表中显示越靠前</div>
        </div>
      
        <div class="admin-page-toolbar__row">
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);">语言</label>
          <select id="productLangId" style="max-width:220px;">
            <option value="all" {{#if (eq selectedLangId '')}}selected{{/if}}>全部</option>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../selectedLangId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
          <label style="font-size:var(--font-size-sm);color:var(--admin-text-muted);">产品分类</label>
          <div class="admin-tree-select" id="productListCategoryTreeSelect" style="max-width:200px; position: relative;">
            <input type="hidden" id="productListCategoryId" value="{{selectedCategoryIdNum}}">
            <div class="admin-tree-select__trigger{{#if selectedCategoryIdNum}} has-value{{/if}}" id="productListCategoryTrigger" style="max-width:200px;">
              <span class="admin-tree-select__placeholder">{{#if selectedCategoryIdNum}}{{#each categories}}{{#if (eq this.id ../selectedCategoryIdNum)}}{{this.name}}{{/if}}{{/each}}{{else}}请选择{{/if}}</span>
              <iconify-icon icon="mdi:chevron-down" class="admin-tree-select__arrow"></iconify-icon>
            </div>
            <div class="admin-tree-select__dropdown" id="productListCategoryDropdown">
              <div class="admin-tree-select__search">
                <input type="text" placeholder="搜索分类..." class="admin-tree-select__search-input" id="productListCategorySearch">
              </div>
              <div class="admin-tree-select__content" id="productListCategoryContent">
                {{#each categories}}
                  <div class="admin-tree-select__item" data-id="{{this.id}}" data-level="{{this.level}}" data-parent-id="{{this.parentId}}">
                    {{#if (gt this.level 0)}}
                      <span class="admin-tree-select__indent" style="width: {{multiply this.level 20}}px;"></span>
                      <iconify-icon icon="mdi:arrow-bottom-right" class="admin-tree-select__icon"></iconify-icon>
                    {{/if}}
                    <span class="admin-tree-select__label">{{this.name}}{{#if this.lang}} ({{this.lang.code}}){{/if}}</span>
                  </div>
                {{/each}}
              </div>
            </div>
          </div>
          <button type="button" class="btn btn-primary" id="btnProductAdd"><iconify-icon icon="mdi:plus"></iconify-icon> 新增</button>
          <button type="button" class="btn btn-secondary" id="btnProductBatchDelete" style="margin-left:0.25rem;"><iconify-icon icon="mdi:delete-sweep"></iconify-icon> 批量删除</button>
          <button type="button" class="btn btn-primary" id="btnProductBatchTranslate" style="margin-left:0.25rem;" disabled><iconify-icon icon="mdi:translate"></iconify-icon> 批量翻译</button>
        </div>
      </div>
      <form id="productBatchDeleteForm" method="post" action="/admin/products/batch-delete" style="display:none;">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
      </form>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th style="width:2.5rem;">
                <input type="checkbox" id="productSelectAll" title="全选" aria-label="全选">
              </th>
              <th>ID</th>
              <th>缩略图</th>
              <th>产品名称</th>
              <th>型号</th>
              <th>排序</th>
              <th id="productLangTh" style="{{#if (eq selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">语言</th>
              <th>分类</th>
              <th>状态</th>
              <th style="width:180px;">操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each productList}}
            <tr>
              <td><input type="checkbox" class="product-row-cb" value="{{this.id}}" aria-label="选择"></td>
              <td>{{this.id}}</td>
              <td>{{#if this.thumbUrl}}<img src="{{this.thumbUrl}}" data-image-preview="{{this.thumbUrl}}" alt="" class="product-list-thumb admin-thumb-clickable" style="max-width:60px;max-height:60px;object-fit:cover;">{{else}}-{{/if}}</td>
              <td>{{this.name}}</td>
              <td>{{this.model}}{{#unless this.model}}-{{/unless}}</td>
              <td>
                <input type="number" class="product-sort-input" data-id="{{this.id}}" value="{{this.sort}}" min="0" style="width:60px;">
              </td>
              <td class="product-lang-cell" style="{{#if (eq ../selectedLangId '')}}display:table-cell;{{else}}display:none;{{/if}}">{{#if this.lang}}{{this.lang.name}} ({{this.lang.code}}){{else}}-{{/if}}</td>
              <td>{{#if this.category}}{{this.category.name}}{{else}}-{{/if}}</td>
              <td>{{#if (eq this.status 1)}}<span class="status-normal">正常</span>{{else}}<span class="status-hidden">隐藏</span>{{/if}}</td>
              <td class="actions">
                <a href="#" class="product-edit-link" data-id="{{this.id}}">编辑</a>
                <a href="#" class="product-translate-link" data-id="{{this.id}}">一键翻译</a>
                <button type="button" class="btn-link product-delete-btn" data-id="{{this.id}}" data-popconfirm="确定删除该产品吗？">删除</button>
              </td>
            </tr>
            {{else}}
            <tr><td colspan="10" style="text-align:center;color:var(--admin-text-muted);">暂无数据</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
      {{#if pagination}}
      <div class="admin-pagination-wrap" style="margin-top:1rem;">
        {{> admin/pagination currentPage=pagination.currentPage totalPages=pagination.totalPages baseUrl=pagination.baseUrl}}
      </div>
      {{/if}}
    </main>
  </div>
  {{> admin/modal-form title="产品"}}
  {{> admin/file-manager-modal}}
  {{> admin/product-params-univer-modal}}
  {{> admin/translate-modal idPrefix="productTranslate"}}
  {{!-- 批量翻译弹窗：勾选目标语言后提交 --}}
  <div id="productBatchTranslateModalOverlay" class="admin-modal-overlay admin-translate-modal-overlay" aria-hidden="true">
    <div class="admin-modal-dialog admin-translate-modal" role="dialog" aria-modal="true" aria-labelledby="productBatchTranslateModalTitle">
      <div class="admin-translate-modal-header">
        <h2 class="admin-translate-modal-title" id="productBatchTranslateModalTitle">批量翻译</h2>
        <button type="button" class="admin-translate-modal-close" id="productBatchTranslateModalClose" aria-label="关闭">
          <iconify-icon icon="mdi:close"></iconify-icon>
        </button>
      </div>
      <div class="admin-translate-modal-body" id="productBatchTranslateModalBody">
        <p style="margin-bottom:0.5rem;">选择要翻译成的语言（可多选）：</p>
        <div style="max-height:200px;overflow:auto;">
          {{#each langs}}
          <label style="display:block;margin-bottom:0.25rem;"><input type="checkbox" class="product-batch-translate-lang-cb" value="{{this.id}}"> {{this.name}} ({{this.code}})</label>
          {{/each}}
        </div>
      </div>
      <div class="admin-translate-modal-footer">
        <div class="admin-translate-modal-actions">
          <button type="button" class="btn btn-secondary" id="productBatchTranslateModalCancel">取消</button>
          <button type="button" class="btn btn-primary" id="productBatchTranslateModalSubmit">开始翻译</button>
        </div>
      </div>
    </div>
  </div>
  {{> admin/image-preview-modal}}
  {{> admin/confirm-modal}}
  <link rel="stylesheet" href="/js/univerjs/index.css" />
  <script src="/js/univerjs/react.production.min.js"></script>
  <script src="/js/univerjs/react-dom.production.min.js"></script>
  <script src="/js/univerjs/rxjs.umd.min.js"></script>
  <script src="/js/univerjs/echarts.min.js"></script>
  <script src="/js/univerjs/presets-index.js"></script>
  <script src="/js/univerjs/preset-sheets-core-index.js"></script>
  <script src="/js/univerjs/zh-CN.js"></script>
  <script>
    (function () {
      var overlay = document.getElementById('productParamsUniverOverlay');
      var confirmBtn = document.getElementById('productParamsUniverConfirm');
      var cancelBtn = document.getElementById('productParamsUniverCancel');
      var closeBtn = document.getElementById('productParamsUniverClose');
      function closeUniverModal() {
        if (overlay) { overlay.classList.remove('open'); overlay.setAttribute('aria-hidden', 'true'); }
      }
      function openUniverModal(dataJsonString, onConfirm) {
        if (!overlay) return;
        overlay.classList.add('open');
        overlay.setAttribute('aria-hidden', 'false');
        window._productParamsExcelOnConfirm = onConfirm;
        if (!window.UniverPresets || !window.UniverCore || !window.UniverPresetSheetsCore) {
          console.warn('Univer 未加载');
          return;
        }
        if (!window._productParamsUniverAPI) {
          try {
            var createUniver = window.UniverPresets.createUniver;
            var LocaleType = window.UniverCore.LocaleType;
            var mergeLocales = window.UniverCore.mergeLocales;
            var UniverSheetsCorePreset = window.UniverPresetSheetsCore.UniverSheetsCorePreset;
            var UniverPresetSheetsCoreZhCN = window.UniverPresetSheetsCoreZhCN || window.UniverPresetSheetsCore['zh-CN'] || {};
            window._productParamsUniverAPI = createUniver({
              locale: LocaleType.ZH_CN,
              locales: { [LocaleType.ZH_CN]: mergeLocales(UniverPresetSheetsCoreZhCN) },
              presets: [UniverSheetsCorePreset({ container: document.getElementById('app') })],
            }).univerAPI;
          } catch (e) {
            console.error('Univer init', e);
            closeUniverModal();
            return;
          }
        }
        var univerAPI = window._productParamsUniverAPI;
        function doCreateAndFill() {
          try {
            var wb = univerAPI.getActiveWorkbook();
            if (wb) {
              var unitId = wb.getId();
              if (unitId) univerAPI.disposeUnit(unitId);
            }
          } catch (e) { /* 无工作簿或已销毁 */ }
          /* 支持两种格式：1) IWorkbookData 完整快照（含样式） 2) 纯二维数组（仅文字，兼容旧数据） */
          var raw = (dataJsonString || '').trim();
          var workbookData = null;
          if (raw) {
            try {
              var p = JSON.parse(raw);
              if (typeof p === 'string') p = JSON.parse(p);
              if (p && typeof p === 'object' && p.sheets && p.sheetOrder && Array.isArray(p.sheetOrder)) {
                p.id = 'product-params-' + Date.now();
                workbookData = p;
              } else if (Array.isArray(p) && p.length) {
                var data = Array.isArray(p[0]) ? p : [p];
                var rows = data.length;
                var cols = Math.max.apply(null, data.map(function (r) { return (r && r.length) || 0; })) || 1;
                var valuesToSet = data.map(function (r) {
                  var row = [];
                  for (var c = 0; c < cols; c++) row.push(String((r && r[c]) != null ? r[c] : ''));
                  return row;
                });
                var cellData = {};
                for (var r = 0; r < rows; r++) {
                  cellData[r] = {};
                  for (var c = 0; c < cols; c++) cellData[r][c] = { v: valuesToSet[r][c] };
                }
                var sheetId = 'sheet1';
                workbookData = {
                  id: 'product-params-' + Date.now(),
                  name: 'Sheet1',
                  sheetOrder: [sheetId],
                  sheets: {}
                };
                workbookData.sheets[sheetId] = { id: sheetId, name: 'Sheet1', cellData: cellData };
              }
            } catch (e) {}
          }
          if (!workbookData) {
            workbookData = {
              id: 'product-params-' + Date.now(),
              name: 'Sheet1',
              sheetOrder: ['sheet1'],
              sheets: { sheet1: { id: 'sheet1', name: 'Sheet1', cellData: { 0: { 0: { v: '' } } } } }
            };
          }
          try {
            univerAPI.createWorkbook(workbookData);
          } catch (e) {
            console.warn('Univer createWorkbook', e);
            closeUniverModal();
            return;
          }
        }
        try {
          if (univerAPI.getActiveWorkbook()) {
            setTimeout(doCreateAndFill, 120);
          } else {
            doCreateAndFill();
          }
        } catch (e) {
          doCreateAndFill();
        }
      }
      window.openProductParamsExcelModal = openUniverModal;
      if (confirmBtn) confirmBtn.onclick = function () {
        var onConfirm = window._productParamsExcelOnConfirm;
        if (window._productParamsUniverAPI && onConfirm) {
          try {
            var wb = window._productParamsUniverAPI.getActiveWorkbook();
            if (!wb) { onConfirm(JSON.stringify([['']])); closeUniverModal(); return; }
            var snapshot = wb.save();
            if (snapshot && typeof snapshot === 'object' && snapshot.sheets) {
              onConfirm(JSON.stringify(snapshot));
            } else {
              var sheet = wb.getActiveSheet();
              var range = sheet.getRange(0, 0, 999, 19);
              var values = range.getValues();
              var maxR = 0, maxC = 0;
              for (var r = 0; r < (values && values.length) || 0; r++) {
                for (var c = 0; c < ((values[r] && values[r].length) || 0); c++) {
                  var v = values[r][c];
                  if (v != null && v !== '') { maxR = Math.max(maxR, r + 1); maxC = Math.max(maxC, c + 1); }
                }
              }
              var trimmed = [];
              for (var r = 0; r < maxR; r++) {
                trimmed.push([]);
                for (var c = 0; c < maxC; c++) trimmed[r].push((values[r] && values[r][c] != null) ? values[r][c] : '');
              }
              onConfirm(maxR && maxC ? JSON.stringify(trimmed) : JSON.stringify([['']]));
            }
          } catch (e) { console.warn(e); onConfirm(JSON.stringify([['']])); }
        }
        closeUniverModal();
      };
      if (cancelBtn) cancelBtn.onclick = closeUniverModal;
      if (closeBtn) closeBtn.onclick = closeUniverModal;
      if (overlay) overlay.onclick = function (e) { if (e.target === overlay) closeUniverModal(); };
    })();
  </script>
  <script>
    (function () {
      var csrfToken = document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').getAttribute('content') : '';
      var formOverlay = document.getElementById('adminModalFormOverlay');
      var formModalBody = document.querySelector('.admin-modal-form-body');
      var formModalTitle = document.getElementById('adminModalFormTitle');

      function openFormModal(titleText, formUrl) {
        if (!formOverlay || !formModalBody) return;
        formModalTitle.textContent = titleText;
        formModalBody.innerHTML = '<p style="text-align:center;color:var(--admin-text-muted);">加载中...</p>';
        formOverlay.classList.add('open');
        formOverlay.setAttribute('aria-hidden', 'false');
        fetch(formUrl, { credentials: 'same-origin' })
          .then(function (r) { return r.text(); })
          .then(function (html) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');
            var frag = doc.getElementById('admin-form-fragment');
            
            // 提取 HTML 和脚本
            var contentHtml = frag ? frag.innerHTML : html;
            var scripts = frag ? frag.querySelectorAll('script') : doc.querySelectorAll('script');
            
            // 先插入 HTML 内容
            formModalBody.innerHTML = contentHtml;
            
            // 手动执行脚本（因为 innerHTML 不会执行 script 标签）
            for (var i = 0; i < scripts.length; i++) {
              var script = scripts[i];
              if (script.src) {
                // 外部脚本
                var newScript = document.createElement('script');
                newScript.src = script.src;
                if (script.type) newScript.type = script.type;
                document.head.appendChild(newScript);
              } else if (script.textContent) {
                // 内联脚本
                try {
                  eval(script.textContent);
                } catch (e) {
                  console.error('执行脚本失败:', e, script.textContent);
                }
              }
            }
            
            var _form = formModalBody.querySelector('form');
            if (_form) { var _inp = document.createElement('input'); _inp.type = 'hidden'; _inp.name = 'returnUrl'; _inp.value = window.location.href; _form.appendChild(_inp); }
            var cancelBtn = formModalBody.querySelector('.admin-modal-form-cancel');
            if (cancelBtn) cancelBtn.onclick = closeFormModal;
            bindProductFormPickers(formModalBody);
          })
          .catch(function () { formModalBody.innerHTML = '<p style="color:var(--admin-danger);">加载失败</p>'; });
      }
      function closeFormModal() {
        if (formOverlay) { formOverlay.classList.remove('open'); formOverlay.setAttribute('aria-hidden', 'true'); }
      }
      function bindProductFormPickers(container) {
        if (!container || !window.AdminFileManager || !window.AdminFileManager.open) return;
        var thumbBtn = container.querySelector('#productBtnPickThumb');
        var thumbInput = container.querySelector('#productThumbUrl');
        var thumbPreview = container.querySelector('#productThumbPreview');
        if (thumbBtn && thumbInput && thumbPreview) thumbBtn.onclick = function () { window.AdminFileManager.open({ type: 'image', targetInput: thumbInput, targetPreview: thumbPreview }); };
        var bannerBtn = container.querySelector('#productBtnPickBanner');
        var bannerInput = container.querySelector('#productBannerUrl');
        var bannerPreview = container.querySelector('#productBannerPreview');
        if (bannerBtn && bannerInput && bannerPreview) bannerBtn.onclick = function () { window.AdminFileManager.open({ type: 'image', targetInput: bannerInput, targetPreview: bannerPreview }); };
        (function initMainPics(cont) {
          if (!cont) return;
          var input = cont.querySelector('#productMainPicsInput');
          var listEl = cont.querySelector('#productMainPicsList');
          var addBtn = cont.querySelector('#productBtnAddMainPic');
          if (!input || !listEl) return;
          function getArr() {
            var val = (input.value || '').trim();
            if (!val) return [];
            try {
              var p = JSON.parse(val);
              return Array.isArray(p) ? p.map(function (s) { return String(s || '').trim(); }).filter(Boolean) : val.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
            } catch (e) {
              return val.split(',').map(function (s) { return s.trim(); }).filter(Boolean);
            }
          }
          function setArr(arr) {
            input.value = JSON.stringify(arr);
            var html = '';
            arr.forEach(function (url, i) {
              var safeUrl = String(url).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            html += '<div class="product-main-pics-item" data-index="' + i + '"><img src="' + safeUrl + '" alt=""><button type="button" class="product-main-pics-remove" aria-label="删除" title="删除">×</button></div>';
            });
            listEl.innerHTML = html;
          }
          listEl.onclick = function (e) {
            var btn = e.target && e.target.classList && e.target.classList.contains('product-main-pics-remove') ? e.target : null;
            if (!btn) return;
            var item = btn.closest('.product-main-pics-item');
            if (!item) return;
            var idx = parseInt(item.getAttribute('data-index'), 10);
            var arr = getArr();
            if (idx >= 0 && idx < arr.length) { arr.splice(idx, 1); setArr(arr); }
          };
          if (addBtn) addBtn.onclick = function () {
            window.AdminFileManager.open({ type: 'image', callback: function (url) {
              var arr = getArr();
              arr.push(url);
              setArr(arr);
            } });
          };
          setArr(getArr());
        })(container);
        (function initProductFeatures(cont) {
          if (!cont) return;
          var container = cont.querySelector('#productFeaturesList');
          var hidden = cont.querySelector('#productFeaturesInput');
          var btnAdd = cont.querySelector('#productBtnAddFeature');
          if (!container || !hidden) {
            console.error('产品特点初始化失败：', { container, hidden, btnAdd });
            return;
          }

          var data = {};
          try { data = JSON.parse(hidden.value || '{}'); } catch (e) { data = {}; }
          if (typeof data !== 'object' || data === null || Array.isArray(data)) data = {};

          function saveToHidden() {
            hidden.value = JSON.stringify(data);
          }

          function render() {
            container.innerHTML = '';
            Object.keys(data).forEach(function (key) {
              var group = document.createElement('div');
              group.className = 'product-features-group';
              group.style.cssText = 'margin:12px 0;padding:12px;background:var(--admin-bg);border-radius:var(--admin-radius);';

              var header = document.createElement('div');
              header.style.cssText = 'display:flex;align-items:center;gap:8px;margin-bottom:8px;';

              var keyInput = document.createElement('input');
              keyInput.type = 'text';
              keyInput.value = key;
              keyInput.placeholder = '分类名称';
              keyInput.style.cssText = 'flex:1;min-width:0;';
              keyInput.dataset.originalKey = key;
              
              keyInput.addEventListener('input', function () {
                var newKey = keyInput.value.trim();
                var originalKey = keyInput.dataset.originalKey;
                if (newKey && newKey !== originalKey) {
                  data[newKey] = data[originalKey];
                  delete data[originalKey];
                  keyInput.dataset.originalKey = newKey;
                  saveToHidden();
                }
              });

              var keyBtnDel = document.createElement('button');
              keyBtnDel.type = 'button';
              keyBtnDel.className = 'btn btn-sm btn-secondary';
              keyBtnDel.textContent = '删除分类';
              keyBtnDel.addEventListener('click', function () {
                if (confirm('确定删除该分类？')) {
                  var originalKey = keyInput.dataset.originalKey;
                  delete data[originalKey];
                  saveToHidden();
                  render();
                }
              });

              header.appendChild(keyInput);
              header.appendChild(keyBtnDel);

              var arr = data[key];
              if (!Array.isArray(arr)) arr = [];

              var items = document.createElement('div');
              items.style.cssText = 'display:flex;flex-direction:column;gap:6px;';

              arr.forEach(function (item, idx) {
                var itemRow = document.createElement('div');
                itemRow.style.cssText = 'display:flex;align-items:center;gap:6px;';

                var itemInput = document.createElement('input');
                itemInput.type = 'text';
                itemInput.value = item;
                itemInput.placeholder = '特性内容';
                itemInput.style.cssText = 'flex:1;min-width:0;';
                itemInput.dataset.index = idx;
                itemInput.dataset.originalKey = key;
                
                itemInput.addEventListener('input', function () {
                  var currentKey = itemInput.dataset.originalKey;
                  var index = parseInt(itemInput.dataset.index, 10);
                  if (data[currentKey] && Array.isArray(data[currentKey])) {
                    data[currentKey][index] = itemInput.value.trim();
                    saveToHidden();
                  }
                });

                var itemBtnDel = document.createElement('button');
                itemBtnDel.type = 'button';
                itemBtnDel.className = 'btn btn-sm btn-secondary';
                itemBtnDel.textContent = '删除';
                itemBtnDel.addEventListener('click', function () {
                  var currentKey = itemInput.dataset.originalKey;
                  var index = parseInt(itemInput.dataset.index, 10);
                  if (data[currentKey] && Array.isArray(data[currentKey])) {
                    data[currentKey].splice(index, 1);
                    saveToHidden();
                    render();
                  }
                });

                itemRow.appendChild(itemInput);
                itemRow.appendChild(itemBtnDel);
                items.appendChild(itemRow);
              });

              var btnAddItem = document.createElement('button');
              btnAddItem.type = 'button';
              btnAddItem.className = 'btn btn-secondary btn-sm';
              btnAddItem.textContent = '新增特性';
              btnAddItem.style.cssText = 'margin-top:6px;';
              btnAddItem.addEventListener('click', function () {
                arr.push('');
                saveToHidden();
