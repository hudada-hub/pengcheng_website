        if (pageSizeSelect) {
          pageSizeSelect.onchange = function () {
            var newPageSize = parseInt(pageSizeSelect.value, 10);
            if (newPageSize && newPageSize !== pageSize) {
              // 构建新的 URL，移除原 pageSize 参数
              var url = '/admin/products';
              var params = [];
              
              // 从 baseUrl 中提取参数
              var baseUrlParts = baseUrl.split('?')[1];
              if (baseUrlParts) {
                var paramPairs = baseUrlParts.split('&');
                for (var i = 0; i < paramPairs.length; i++) {
                  var pair = paramPairs[i].split('=');
                  var key = decodeURIComponent(pair[0]);
                  var value = decodeURIComponent(pair[1] || '');
                  // 跳过 pageSize 和 page 参数
                  if (key !== 'pageSize' && key !== 'page') {
                    params.push(key + '=' + value);
                  }
                }
              }
              
              // 添加新的 page=1 和新的 pageSize
              params.push('page=1');
              params.push('pageSize=' + newPageSize);
              
              window.location.href = url + '?' + params.join('&');
            }
          };
        }
        
        // 跳转页码
        var jumpInput = paginationNav.querySelector('.admin-pagination-jump-input');
        var jumpBtn = paginationNav.querySelector('.admin-pagination-jump-btn');
        if (jumpInput && jumpBtn && baseUrl) {
