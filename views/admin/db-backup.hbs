<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 鹏成后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <script src="/js/iconify-icon.min.js"></script>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
        <h1 style="margin:0;">{{title}}</h1>
        <form method="post" action="/admin/db-backup/run" style="display:inline;">
          <input type="hidden" name="_csrf" value="{{csrfToken}}">
          <button type="submit" class="btn btn-primary">
            <iconify-icon icon="mdi:database-export-outline"></iconify-icon>
            立即备份
          </button>
        </form>
      </div>

      <p class="admin-desc">系统会每 2 天自动备份一次。备份文件存储在服务器本地目录。</p>

      {{#if error}}
        <div class="admin-card" style="border:1px solid rgba(220,38,38,0.25);background:#fef2f2;">
          <p style="color:#991b1b;margin:0;">{{error}}</p>
        </div>
      {{/if}}
      {{#if message}}
        <div class="admin-card" style="border:1px solid rgba(37,99,235,0.25);background:#eff6ff;">
          <p style="color:#1e40af;margin:0;">{{message}}</p>
        </div>
      {{/if}}

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>文件名</th>
              <th>大小</th>
              <th>创建时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each backups}}
            <tr>
              <td style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;">{{this.fileName}}</td>
              <td data-size="{{this.size}}">{{this.size}}</td>
              <td>{{this.createdAt}}</td>
              <td class="actions">
                <a href="/admin/db-backup/download/{{this.fileName}}">下载</a>
                <form method="post" action="/admin/db-backup/restore" style="display:inline;">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <input type="hidden" name="fileName" value="{{this.fileName}}">
                  <button type="submit" data-popconfirm="确定要用该备份恢复数据库吗？此操作会覆盖现有数据。">恢复</button>
                </form>
                <form method="post" action="/admin/db-backup/delete" style="display:inline;">
                  <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                  <input type="hidden" name="fileName" value="{{this.fileName}}">
                  <button type="submit" data-popconfirm="确定删除该备份文件吗？">删除</button>
                </form>
              </td>
            </tr>
            {{else}}
            <tr><td colspan="4" style="text-align:center;color:var(--admin-text-muted);">暂无备份文件</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </main>
  </div>

  {{> admin/confirm-modal}}

  <script>
    (function () {
      var csrfMeta = document.querySelector('meta[name="csrf-token"]');
      var csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : '';
      var btn = document.getElementById('btn-clear-cache');
      if (btn) btn.onclick = function () {
        fetch('/admin/clear-cache', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ _csrf: csrfToken }) })
          .then(function (r) { return r.json(); }).then(function (d) { alert(d.message || '完成'); }).catch(function () { alert('请求失败'); });
      };

      var formatBytes = function (bytes) {
        var b = Number(bytes || 0);
        if (!isFinite(b)) return '-';
        var units = ['B', 'KB', 'MB', 'GB', 'TB'];
        var i = 0;
        while (b >= 1024 && i < units.length - 1) { b /= 1024; i++; }
        return (i === 0 ? String(Math.round(b)) : b.toFixed(2)) + ' ' + units[i];
      };
      document.querySelectorAll('td[data-size]').forEach(function (td) {
        td.textContent = formatBytes(td.getAttribute('data-size'));
      });
    })();
  </script>
</body>
</html>

