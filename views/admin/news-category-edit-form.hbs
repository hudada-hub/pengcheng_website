<!DOCTYPE html>
<html><head><meta charset="UTF-8"></head><body><div id="admin-form-fragment">
  <div class="admin-card">
    <form class="admin-form" method="post" action="/admin/news-category/save">
      <div class="admin-modal-form-scroll">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        {{#if category}}<input type="hidden" name="id" value="{{category.id}}">{{/if}}
        <div class="form-group">
          <label>名称 <span style="color:var(--admin-danger);">*</span></label>
          <input type="text" name="name" id="ncName" required value="{{#if category}}{{category.name}}{{/if}}" placeholder="分类名称">
        </div>
        <div class="form-group">
          <label>SEO 标题（默认与名称一致）</label>
          <input type="text" name="metaTitle" id="ncMetaTitle" value="{{#if category}}{{#if category.metaTitle}}{{category.metaTitle}}{{else}}{{category.name}}{{/if}}{{/if}}" placeholder="留空则使用名称">
        </div>
        <div class="form-group">
          <label>SEO 关键词</label>
          <textarea name="metaKeywords" rows="2" placeholder="meta keywords">{{#if category}}{{category.metaKeywords}}{{/if}}</textarea>
        </div>
        <div class="form-group">
          <label>SEO 描述</label>
          <textarea name="metaDescription" rows="2" placeholder="meta description">{{#if category}}{{category.metaDescription}}{{/if}}</textarea>
        </div>
        <div class="form-group">
          <label>类型</label>
          <select name="type">
            <option value="1" {{#if category}}{{#if (eq category.type 1)}}selected{{/if}}{{else}}selected{{/if}}>新闻</option>
            <option value="2" {{#if category}}{{#if (eq category.type 2)}}selected{{/if}}{{/if}}>活动</option>
          </select>
        </div>
        <div class="form-group">
          <label>语言 <span style="color:var(--admin-danger);">*</span></label>
          <select name="langId" required>
            {{#each langs}}
              <option value="{{this.id}}" {{#if (eq this.id ../defaultLangId)}}selected{{/if}}>{{this.name}} ({{this.code}})</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>排序（数字越小越靠前）</label>
          <input type="number" name="sort" value="{{#if category}}{{category.sort}}{{else}}0{{/if}}" min="0">
        </div>
        <div class="form-group">
          <label>Banner 图 URL</label>
          <div class="admin-input-row">
            <input type="text" name="bannerUrl" id="ncBannerUrl" value="{{#if category}}{{category.bannerUrl}}{{/if}}" placeholder="可选，或点击选择">
            <button type="button" class="btn" id="ncBtnPickBanner"><iconify-icon icon="mdi:image-search-outline"></iconify-icon> 选择</button>
            <span class="admin-input-preview" id="ncBannerUrlPreview">{{#if category}}{{#if category.bannerUrl}}<img src="{{category.bannerUrl}}" alt="">{{/if}}{{/if}}</span>
          </div>
        </div>
        <div class="form-group">
          <label>状态</label>
          <select name="status">
            <option value="1" {{#if category}}{{#if (eq category.status 1)}}selected{{/if}}{{else}}selected{{/if}}>正常</option>
            <option value="0" {{#if category}}{{#if (eq category.status 0)}}selected{{/if}}{{/if}}>隐藏</option>
          </select>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">保存</button>
        <button type="button" class="btn admin-modal-form-cancel">取消</button>
      </div>
    </form>
  </div>
</div></body></html>
