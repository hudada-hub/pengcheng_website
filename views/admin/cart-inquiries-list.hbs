<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}} - 鹏成后台</title>
  <meta name="csrf-token" content="{{csrfToken}}">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/admin/admin-theme.css">
  <script src="/js/iconify-icon.min.js"></script>
  <script src="/js/admin-pagination.js"></script>
</head>
<body class="admin-layout">
  {{> admin/header}}
  <div class="admin-body">
    {{> admin/sidebar}}
    <main class="admin-main">
      <div class="admin-page-toolbar">
        <h1 style="margin:0;">{{title}}</h1>
        <p style="margin:0;font-size:var(--font-size-sm);color:var(--admin-text-muted);">购物车询价表单记录，关联订单数据可查看用户提交的商品</p>
      </div>

      <!-- 搜索表单 -->
      <div class="admin-search-bar" style="padding:16px;background:#f8f9fa;border-radius:8px;margin-bottom:16px;">
        <form method="GET" action="/admin/cart-inquiries" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
          <input type="hidden" name="pageSize" value="{{pagination.pageSize}}">
          <div style="display:flex;flex-direction:column;gap:4px;">
            <label style="font-size:12px;color:#666;">订单号</label>
            <input type="text" name="orderNumber" value="{{search.orderNumber}}" placeholder="输入订单UUID" style="padding:8px 12px;border:1px solid #ddd;border-radius:4px;min-width:200px;">
          </div>
          <div style="display:flex;flex-direction:column;gap:4px;">
            <label style="font-size:12px;color:#666;">联系人</label>
            <input type="text" name="contactName" value="{{search.contactName}}" placeholder="输入联系人姓名" style="padding:8px 12px;border:1px solid #ddd;border-radius:4px;min-width:150px;">
          </div>
          <div style="display:flex;flex-direction:column;gap:4px;">
            <label style="font-size:12px;color:#666;">邮箱</label>
            <input type="text" name="email" value="{{search.email}}" placeholder="输入邮箱地址" style="padding:8px 12px;border:1px solid #ddd;border-radius:4px;min-width:200px;">
          </div>
          <button type="submit" class="admin-btn admin-btn-primary" style="display:flex;align-items:center;gap:6px;">
            <iconify-icon icon="mdi:magnify"></iconify-icon>
            搜索
          </button>
          {{#if search.orderNumber}}{{#unless (eq search.orderNumber '')}}<a href="/admin/cart-inquiries?pageSize={{pagination.pageSize}}" class="admin-btn" style="text-decoration:none;">重置</a>{{/unless}}{{/if}}
          {{#if search.contactName}}{{#unless (eq search.contactName '')}}<a href="/admin/cart-inquiries?pageSize={{pagination.pageSize}}" class="admin-btn" style="text-decoration:none;">重置</a>{{/unless}}{{/if}}
          {{#if search.email}}{{#unless (eq search.email '')}}<a href="/admin/cart-inquiries?pageSize={{pagination.pageSize}}" class="admin-btn" style="text-decoration:none;">重置</a>{{/unless}}{{/if}}
        </form>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>用户信息</th>
              <th>联系人</th>
              <th>联系方式</th>
              <th>留言</th>
              <th>来源页面</th>
              <th>关联订单</th>
              <th>提交时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            {{#each list}}
            <tr>
              <td>{{this.id}}</td>
              <td>
                <div>用户ID: {{this.userId}}</div>
                <div>{{this.userName}}</div>
                <div class="text-muted">{{this.userEmail}}</div>
                {{#if this.source}}
                  <span class="badge {{#if (eq this.source 'contact')}}badge-info{{else}}badge-primary{{/if}}">
                    {{#if (eq this.source 'contact')}}联系表单{{else}}购物车询价{{/if}}
                  </span>
                {{/if}}
              </td>
              <td>
                {{#if this.fullName}}
                  <div>{{this.fullName}}</div>
                {{else}}
                  <span class="text-muted">-</span>
                {{/if}}
              </td>
              <td>
                {{#if this.email}}
                  <div><strong>邮箱:</strong> {{this.email}}</div>
                {{/if}}
                {{#if this.phoneNumber}}
                  <div><strong>电话:</strong> {{this.phoneNumber}}</div>
                {{/if}}
                {{#if this.nation}}
                  <div><strong>国家:</strong> {{this.nation}}</div>
                {{/if}}
                {{#if this.locationCity}}
                  <div><strong>城市:</strong> {{this.locationCity}}</div>
                {{/if}}
              </td>
              <td>
                {{#if this.message}}
                  <div class="message-preview" title="{{this.message}}">{{this.message}}</div>
                {{else}}
                  <span class="text-muted">-</span>
                {{/if}}
              </td>
              <td>
                {{#if this.sourceUrl}}
                  <a href="{{this.sourceUrl}}" target="_blank" class="source-url" title="{{this.sourceUrl}}">{{this.sourceUrl}}</a>
                {{else}}
                  <span class="text-muted">-</span>
                {{/if}}
              </td>
              <td>
                {{#if this.hasOrderData}}
                  <details class="order-details">
                    <summary>查看订单商品 ({{this.orderItems.length}}件)</summary>
                    <div class="order-items">
                      {{#each this.orderItems}}
                      <div class="order-item">
                        {{#if this.thumbUrl}}
                        <img src="{{this.thumbUrl}}" alt="" class="order-item-thumb" />
                        {{/if}}
                        <div class="order-item-info">
                          <div class="order-item-name">{{this.productName}}</div>
                          <div class="order-item-qty">数量: {{this.quantity}}</div>
                        </div>
                      </div>
                      {{/each}}
                    </div>
                  </details>
                {{else}}
                  <span class="text-muted">无订单数据</span>
                {{/if}}
              </td>
              <td>{{this.createdAtFormatted}}</td>
              <td>
                <button type="button" class="btn-link inquiry-delete-btn" data-id="{{this.id}}" data-popconfirm="确定删除该询价记录吗？">删除</button>
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="8" class="text-center text-muted">暂无数据</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      {{#if pagination}}
        {{> admin/pagination currentPage=pagination.currentPage totalPages=pagination.totalPages pageSize=pagination.pageSize baseUrl=pagination.baseUrl}}
      {{/if}}
    </main>
  </div>

  <style>
    .message-preview {
      max-width: 200px;
      max-height: 60px;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      font-size: 13px;
      line-height: 1.4;
    }
    .source-url {
      max-width: 200px;
      max-height: 40px;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      font-size: 12px;
      color: #666;
    }
    .order-details {
      font-size: 13px;
    }
    .order-details summary {
      cursor: pointer;
      color: #0066cc;
    }
    .order-items {
      margin-top: 8px;
      padding: 8px;
      background: #f5f5f5;
      border-radius: 4px;
    }
    .order-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 4px 0;
      border-bottom: 1px solid #e0e0e0;
    }
    .order-item:last-child {
      border-bottom: none;
    }
    .order-item-thumb {
      width: 40px;
      height: 40px;
      object-fit: cover;
      border-radius: 4px;
    }
    .order-item-info {
      flex: 1;
    }
    .order-item-name {
      font-size: 12px;
      font-weight: 500;
    }
    .order-item-qty {
      font-size: 11px;
      color: #666;
    }
    .text-muted {
      color: #999;
    }
    .text-center {
      text-align: center;
    }
  </style>
  <script>
    (function() {
      document.querySelectorAll('.inquiry-delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          var id = btn.getAttribute('data-id');
          var msg = btn.getAttribute('data-popconfirm') || '确定删除该询价记录吗？';
          showConfirmModal(msg, function() {
            var csrf = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
            fetch('/admin/cart-inquiries/' + id, {
              method: 'DELETE',
              headers: {
                'x-csrf-token': csrf
              },
              credentials: 'same-origin'
            })
            .then(function(res) { return res.json(); })
            .then(function(d) {
              if (d && d.ok) {
                alert(d.message || '删除成功');
                location.reload();
              } else {
                alert(d && d.message ? d.message : '删除失败');
              }
            })
            .catch(function() { alert('删除失败'); });
          });
        });
      });
    })();
  </script>
</body>
</html>
